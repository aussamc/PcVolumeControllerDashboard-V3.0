                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderInnerFill}" StrokeThickness="1.2" Margin="17" />
                                                        <Line X1="43" Y1="4" X2="43" Y2="22" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="43" Y1="64" X2="43" Y2="82" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="4" Y1="43" X2="22" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="64" Y1="43" X2="82" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
