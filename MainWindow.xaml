                                                        <Line X1="64" Y1="43" X2="82" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <TextBlock Text="+" FontSize="26" Foreground="{DynamicResource PreviewEncoderStroke}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </UniformGrid>
                                        </Grid>
                                    </Border>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Button x:Name="SaveOledSetupButton"
                                Content="Save OLED Setup"
                                Width="160"
                                Height="34"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,12"
                                Click="SaveOledSetupButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <TabItem Header="Setup">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="PC Volume Controller"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock x:Name="SettingsDashboardVersionTextBlock"
                                           Text="Dashboard version: v2.15"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsExpectedProtocolTextBlock"
                                           Text="Required ESP32 protocol: v2.15"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsFirmwareVersionTextBlock"
                                           Text="Connected ESP32 firmware: Not connected"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsBuildTypeTextBlock"
                                           Text="Build type: Unknown"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsActiveLogFileTextBlock"
                                           Text="Active log file:"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource SecondaryForeground}" />
<StackPanel Orientation="Horizontal" Margin="0,0,0,0">
    <TextBlock Text="Log folder: "
               Foreground="{DynamicResource SecondaryForeground}"
               VerticalAlignment="Center" />
    <Button x:Name="SettingsLogFolderButton"
            Content="Open log folder"
            Padding="0"
            BorderThickness="0"
            Background="Transparent"
            Foreground="#0066CC"
            Cursor="Hand"
            Click="OpenLogFolderButton_Click" />
</StackPanel>

                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="OpenCurrentLogFileButton" Content="Open Current Log" Width="140" Height="30" Margin="0,0,8,8" Click="OpenCurrentLogFileButton_Click" />
                                    <Button x:Name="CopyLogFolderPathButton" Content="Copy Log Folder Path" Width="170" Height="30" Margin="0,0,8,8" Click="CopyLogFolderPathButton_Click" />
                                    <Button x:Name="ExportDiagnosticsZipButton" Content="Export Diagnostics Zip" Width="170" Height="30" Margin="0,0,8,8" Click="ExportDiagnosticsZipButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Application Setup"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <CheckBox x:Name="AutoConnectCheckBox"
                                          Content="Auto-connect on launch"
                                          Margin="0,0,0,8" />

                                <CheckBox x:Name="ScanAllComPortsCheckBox"
                                          Content="Scan all COM ports if remembered controller is missing"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Leave this off for daily use so the dashboard waits for the remembered controller port instead of probing unrelated COM ports."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="22,-4,0,8" />

                                <CheckBox x:Name="MinimizeToTrayCheckBox"
                                          Content="Minimize to system tray"
                                          Margin="0,0,0,8" />

                                <CheckBox x:Name="StartMinimizedToTrayCheckBox"
                                          Content="Start minimized to tray"
                                          Margin="0,0,0,8" />

                                <CheckBox x:Name="StartWithWindowsCheckBox"
                                          Content="Start program on Windows startup"
                                          Margin="0,0,0,8" />

                                <CheckBox x:Name="AdvancedDebugLoggingCheckBox"
                                          Content="Advanced debug logging"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Startup now restores saved channels and friendly names before apps are opened."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>




                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Encoder Sensitivity"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Controls how much the volume changes for each encoder click. 50% is the default; higher values allow much faster changes."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />

                                <Grid Width="420" HorizontalAlignment="Left">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Slider Grid.Row="0"
                                            x:Name="EncoderSensitivitySlider"
                                            Minimum="0"
                                            Maximum="500"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="False"
                                            ValueChanged="EncoderSensitivitySlider_ValueChanged"
                                            PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="Slider_PreviewMouseMove"
                                            PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="Slider_LostMouseCapture"
                                            Width="420"
                                            HorizontalAlignment="Left" />

                                    <Grid Grid.Row="1" Margin="0,2,0,0">
                                        <TextBlock Text="0%" HorizontalAlignment="Left" />
                                        <TextBlock Text="500%" HorizontalAlignment="Right" />
                                    </Grid>
                                </Grid>

                                <TextBlock x:Name="EncoderSensitivityValueTextBlock"
                                           Text="Sensitivity: 50%"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Encoder Feel"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Volume acceleration scales the volume step when you turn the encoder quickly. Volume smoothing eases the volume to its target over a short time rather than jumping instantly."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           Margin="0,0,0,12" />

                                <!-- Acceleration -->
                                <CheckBox x:Name="AccelerationEnabledCheckBox"
                                          Content="Enable volume acceleration"
                                          Margin="0,0,0,8"
                                          Checked="AccelerationEnabledCheckBox_Changed"
                                          Unchecked="AccelerationEnabledCheckBox_Changed" />

                                <Grid Margin="0,0,0,16" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Acceleration preset:"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              x:Name="AccelerationPresetComboBox"
                                              Height="30"
                                              SelectionChanged="AccelerationPresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Light" />
                                        <ComboBoxItem Content="Medium" />
                                        <ComboBoxItem Content="Aggressive" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>
                                </Grid>

                                <!-- Custom acceleration tuning panel — visible only when "Custom" preset is selected -->
                                <StackPanel x:Name="AccelCustomPanel"
                                            Margin="0,8,0,4"
                                            Visibility="Collapsed">

                                    <TextBlock Text="Custom acceleration tuning"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />

                                    <!-- Speed threshold -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Speed threshold:" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                x:Name="AccelThresholdSlider"
                                                Minimum="20" Maximum="250"
                                                TickFrequency="10" IsSnapToTickEnabled="True"
                                                ValueChanged="AccelThresholdSlider_ValueChanged"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" x:Name="AccelThresholdLabel"
                                                   Text="120 ms" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Turn interval below which acceleration starts. Higher = kicks in earlier."
                                               FontSize="11" Opacity="0.6" Margin="170,0,0,8" TextWrapping="Wrap" />

                                    <!-- Max multiplier -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Max multiplier:" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                x:Name="AccelMaxMultiplierSlider"
                                                Minimum="1.5" Maximum="8.0"
                                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                                ValueChanged="AccelMaxMultiplierSlider_ValueChanged"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" x:Name="AccelMaxMultiplierLabel"
                                                   Text="4.0×" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Maximum step size boost when turning at full speed."
                                               FontSize="11" Opacity="0.6" Margin="170,0,0,8" TextWrapping="Wrap" />

                                    <!-- Curve exponent -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Curve shape:" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                x:Name="AccelCurveSlider"
                                                Minimum="0.3" Maximum="2.5"
                                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                ValueChanged="AccelCurveSlider_ValueChanged"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" x:Name="AccelCurveLabel"
                                                   Text="Soft" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Early/Soft = acceleration builds quickly; Linear = even ramp; Late/Sharp = boost only at max speed."
                                               FontSize="11" Opacity="0.6" Margin="170,0,0,8" TextWrapping="Wrap" />

                                    <!-- Live preview -->
                                    <TextBlock x:Name="AccelPreviewLabel"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Margin="0,0,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Smoothing -->
                                <CheckBox x:Name="VolumeSmoothingEnabledCheckBox"
                                          Content="Enable volume smoothing"
                                          Margin="0,0,0,8"
                                          Checked="VolumeSmoothingEnabledCheckBox_Changed"
                                          Unchecked="VolumeSmoothingEnabledCheckBox_Changed" />

                                <Grid HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Smoothing speed:"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              x:Name="VolumeSmoothingSpeedComboBox"
                                              Height="30"
                                              SelectionChanged="VolumeSmoothingSpeedComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Fast (~60 ms)" />
                                        <ComboBoxItem Content="Normal (~100 ms)" />
                                        <ComboBoxItem Content="Slow (~150 ms)" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Style Settings"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <RadioButton x:Name="ThemeFollowSystemRadioButton"
                                             Content="Follow System"
                                             GroupName="ThemeMode"
                                             Margin="0,0,0,8"
                                             Checked="ThemeRadioButton_Checked" />

                                <RadioButton x:Name="ThemeLightRadioButton"
                                             Content="Light Mode"
                                             GroupName="ThemeMode"
                                             Margin="0,0,0,8"
                                             Checked="ThemeRadioButton_Checked" />

                                <RadioButton x:Name="ThemeDarkRadioButton"
                                             Content="Dark Mode"
                                             GroupName="ThemeMode"
                                             Margin="0,0,0,8"
                                             Checked="ThemeRadioButton_Checked" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Device Diagnostics"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock x:Name="DiagConnectionTextBlock" Text="ESP32 connection: Disconnected" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagComPortTextBlock" Text="COM port: --" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagLastHeartbeatTextBlock" Text="Last message: --" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagFirmwareTextBlock" Text="Firmware: Unknown" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagProtocolTextBlock" Text="Protocol: Unknown / Required 1.3" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagProtocolStatusTextBlock" Text="Protocol status: Waiting for ESP32" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagLastMessageTextBlock" Text="Last ESP32 message: --" Margin="0,0,0,4" TextWrapping="Wrap" />
                                <TextBlock x:Name="DiagLastStateSentTextBlock" Text="Last state sent: --" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Margin="0,0,0,12">
                            <Button x:Name="ExportSetupButton" Content="Export Setup" Width="130" Height="34" Margin="0,0,8,8" Click="ExportSetupButton_Click" />
                            <Button x:Name="ImportSetupButton" Content="Import Setup" Width="130" Height="34" Margin="0,0,8,8" Click="ImportSetupButton_Click" />
                            <Button x:Name="ClearRememberedControllerButton" Content="Clear Remembered Controller" Width="210" Height="34" Margin="0,0,8,8" Click="ClearRememberedControllerButton_Click" />
                            <Button x:Name="FactoryResetSetupButton" Content="Factory Reset Setup" Width="170" Height="34" Margin="0,0,8,8" Click="FactoryResetSetupButton_Click" />
                        </WrapPanel>

                        <Button x:Name="SaveSettingsButton"
                                Content="Save Setup"
                                Width="130"
                                Height="34"
                                HorizontalAlignment="Left"
                                Click="SaveSettingsButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Firmware">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ESP32 Firmware Update" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Use bundled firmware binaries when available, or select a manually built ESP32 .bin file. The dashboard looks for esptool in the tools folder." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <TextBlock Text="Bundled firmware source: Computer_Volume_Controller_v2.15" Margin="0,0,0,4" />
                                <TextBlock x:Name="FirmwareStatusTextBlock" Text="Compiled binaries: see firmware_bin/build_instructions.txt if binaries are not present" Margin="0,0,0,6" TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedFirmwareBinTextBlock" Text="Selected .bin file: none" Margin="0,0,0,10" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" />
                                <WrapPanel Margin="0,0,0,8">
                                    <Button x:Name="SelectFirmwareBinButton" Content="Select .bin File" Width="130" Height="34" Margin="0,0,8,8" Click="SelectFirmwareBinButton_Click" />
                                    <Button x:Name="FlashFirmwareButton" Content="Flash ESP32 Firmware" Width="180" Height="34" Margin="0,0,8,8" Click="FlashFirmwareButton_Click" />
                                </WrapPanel>
                                <TextBox x:Name="FirmwareFlashOutputTextBox" Margin="0,12,0,0" MinHeight="180" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Hardware Test">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Hardware Test Mode" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Use this to verify encoder direction, button presses, and display commands before relying on Windows audio control." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Content="Send Display Test" Width="140" Height="30" Margin="0,0,8,8" Click="SendHardwareTestPatternButton_Click" />
                                    <Button Content="Show OLED Numbers" Width="150" Height="30" Margin="0,0,8,8" Click="SendShowOledIdentButton_Click" />
                                    <Button Content="Sleep Display" Width="120" Height="30" Margin="0,0,8,8" Click="SendHardwareSleepButton_Click" />
                                    <Button Content="Wake Display" Width="120" Height="30" Margin="0,0,8,8" Click="SendHardwareWakeButton_Click" />
                                    <Button Content="Reset Counters" Width="130" Height="30" Margin="0,0,8,8" Click="ResetHardwareTestButton_Click" />
                                </WrapPanel>
                                <TextBlock x:Name="HardwareTestStatusTextBlock" Text="No hardware events received yet." TextWrapping="Wrap" FontFamily="Consolas" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Debug">
                <Grid Margin="0,12,0,0" Background="{DynamicResource AppBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Serial / Debug Console" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <WrapPanel>
                                <CheckBox x:Name="ShowHeartbeatDebugCheckBox" Content="Show PING/PONG heartbeat" Margin="0,0,16,8" />
                                <Button Content="Clear" Width="80" Height="30" Margin="0,0,8,8" Click="ClearDebugConsoleButton_Click" />
                                <Button Content="Copy" Width="80" Height="30" Margin="0,0,8,8" Click="CopyDebugConsoleButton_Click" />
                                <Button Content="Save Snapshot" Width="130" Height="30" Margin="0,0,8,8" Click="SaveDebugSnapshotButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <TextBox Grid.Row="1" x:Name="DebugConsoleTextBox" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                </Grid>
            </TabItem>
            <TabItem x:Name="FirstRunWizardTab" Header="First Run">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="First-Run Setup Wizard" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Use this page to confirm the controller, choose startup behaviour, and then jump to the Audio page to assign channels." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,12" />
                                <TextBlock x:Name="WizardStatusTextBlock" Text="Wizard status: not checked" Margin="0,0,0,4" FontWeight="SemiBold" />
                                <TextBlock x:Name="WizardControllerStatusTextBlock" Text="Controller: not checked" Margin="0,0,0,4" TextWrapping="Wrap" />
                                <TextBlock x:Name="WizardFirmwareStatusTextBlock" Text="Firmware/protocol: not checked" Margin="0,0,0,4" TextWrapping="Wrap" />
                                <TextBlock x:Name="WizardStartupStatusTextBlock" Text="Startup: not checked" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="1. Detect the controller" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Plug in the PC Volume Controller, then click Detect Controller. The dashboard will verify the ESP32 identity before accepting the COM port." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <Button Content="Detect Controller" Width="150" Height="34" HorizontalAlignment="Left" Click="WizardDetectControllerButton_Click" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="2. Choose daily-use startup behaviour" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardAutoConnectCheckBox" Content="Auto-connect to the controller when the dashboard opens" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardStartWithWindowsCheckBox" Content="Start dashboard when Windows starts" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardMinimizeToTrayCheckBox" Content="Minimize to system tray" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardStartMinimizedCheckBox" Content="Start minimized to tray" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardScanAllCheckBox" Content="Scan all COM ports if the remembered controller is missing" Margin="0,0,0,8" />
                                <TextBlock Text="Recommended daily-use setup: auto-connect on, start with Windows on, minimize to tray on, start minimized on, scan all COM ports off." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,10" />
                                <WrapPanel>
                                    <Button Content="Apply Recommended" Width="150" Height="34" Margin="0,0,8,8" Click="WizardApplyRecommendedButton_Click" />
                                    <Button Content="Save Wizard Choices" Width="160" Height="34" Margin="0,0,8,8" Click="WizardSaveSetupButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="3. Assign channels" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Open the Audio page to assign each encoder to Master volume, an app, or leave it unassigned." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <WrapPanel>
                                    <Button Content="Open Audio Page" Width="140" Height="34" Margin="0,0,8,8" Click="WizardOpenAudioPageButton_Click" />
                                    <Button Content="Mark Wizard Complete" Width="170" Height="34" Margin="0,0,8,8" Click="WizardCompleteButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Margin="0,12,0,0">
            <TextBlock x:Name="LogTextBlock"
                       Text="Ready."
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>