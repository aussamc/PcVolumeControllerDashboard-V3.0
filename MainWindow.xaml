                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="PC Volume Controller"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock x:Name="SettingsDashboardVersionTextBlock"
                                           Text=""
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsExpectedProtocolTextBlock"
                                           Text=""
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsFirmwareVersionTextBlock"
                                           Text="Connected ESP32 firmware: Not connected"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsBuildTypeTextBlock"
                                           Text="Build type: Unknown"
                                           Margin="0,0,0,4" />

                                <TextBlock x:Name="SettingsActiveLogFileTextBlock"
                                           Text="Active log file:"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource SecondaryForeground}" />
<StackPanel Orientation="Horizontal" Margin="0,0,0,0">
    <TextBlock Text="Log folder: "
               Foreground="{DynamicResource SecondaryForeground}"
               VerticalAlignment="Center" />
    <Button x:Name="SettingsLogFolderButton"
            Content="Open log folder"
            Padding="0"
            BorderThickness="0"
            Background="Transparent"
            Foreground="#0066CC"
            Cursor="Hand"
            Click="OpenLogFolderButton_Click" />
</StackPanel>

                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="OpenCurrentLogFileButton" Content="Open Current Log" Width="140" Height="30" Margin="0,0,8,8" Click="OpenCurrentLogFileButton_Click" />
                                    <Button x:Name="CopyLogFolderPathButton" Content="Copy Log Folder Path" Width="170" Height="30" Margin="0,0,8,8" Click="CopyLogFolderPathButton_Click" />
                                    <Button x:Name="ExportDiagnosticsZipButton" Content="Export Diagnostics Zip" Width="170" Height="30" Margin="0,0,8,8" ToolTip="Export a diagnostics zip containing logs and settings for bug reports" Click="ExportDiagnosticsZipButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Application Setup"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <CheckBox x:Name="AutoConnectCheckBox"
                                          Content="Auto-connect on launch"
                                          Margin="0,0,0,8"
                                          ToolTip="Automatically connect to the controller when the dashboard opens" />

                                <CheckBox x:Name="ScanAllComPortsCheckBox"
                                          Content="Scan all COM ports if remembered controller is missing"
                                          Margin="0,0,0,8"
                                          ToolTip="Scan all COM ports for the controller if the remembered port is not found. Leave off for daily use." />

                                <TextBlock Text="Leave this off for daily use so the dashboard waits for the remembered controller port instead of probing unrelated COM ports."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="22,-4,0,8" />

                                <CheckBox x:Name="MinimizeToTrayCheckBox"
                                          Content="Minimize to system tray"
                                          Margin="0,0,0,8"
                                          ToolTip="Minimize the dashboard to the system tray instead of closing" />

                                <CheckBox x:Name="StartMinimizedToTrayCheckBox"
                                          Content="Start minimized to tray"
                                          Margin="0,0,0,8"
                                          ToolTip="Start the dashboard minimized to the system tray" />

                                <CheckBox x:Name="StartWithWindowsCheckBox"
                                          Content="Start program on Windows startup"
                                          Margin="0,0,0,8"
                                          ToolTip="Automatically launch the dashboard when Windows starts" />

                                <CheckBox x:Name="AdvancedDebugLoggingCheckBox"
                                          Content="Advanced debug logging"
                                          Margin="0,0,0,8"
                                          ToolTip="Write verbose debug output to the log file. Useful for troubleshooting." />

                                <TextBlock Text="Startup now restores saved channels and friendly names before apps are opened."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />

                                <Button x:Name="ShowFirstRunWizardButton"
                                        Content="Show setup guide"
                                        HorizontalAlignment="Left"
                                        Padding="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="#0066CC"
                                        Cursor="Hand"
                                        Margin="0,8,0,0"
                                        Click="ShowFirstRunWizardButton_Click" />

                                <Separator Margin="0,12,0,8"/>
