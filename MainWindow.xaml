                                <RadioButton x:Name="VoiceMeeterRadioButton"
                                             Content="VoiceMeeter (route through VoiceMeeter strips and buses)"
                                             GroupName="AudioBackendGroup"
                                             Margin="0,0,0,12" />

                                <WrapPanel Margin="0,0,0,8" VerticalAlignment="Center">
                                    <TextBlock Text="VoiceMeeter status: "
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryForeground}" />
                                    <TextBlock x:Name="VoiceMeeterStatusTextBlock"
                                               Text="Not active"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryForeground}" />
                                </WrapPanel>

                                <Button x:Name="AudioBackendApplyButton"
                                        Content="Apply Backend Change"
