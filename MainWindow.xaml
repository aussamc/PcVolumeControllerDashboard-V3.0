<Window x:Class="PcVolumeControllerDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Volume Controller Dashboard"
        Icon="Assets/app-icon.ico"
        Height="900"
        Width="1300"
        MinWidth="570"
        MinHeight="320"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource AppForeground}">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground"                  Color="#0D0F11" />
        <SolidColorBrush x:Key="CardBackground"                 Color="#1A1D20" />
        <SolidColorBrush x:Key="AppForeground"                  Color="#F2F2F2" />
        <SolidColorBrush x:Key="SecondaryForeground"            Color="#7A7F88" />
        <SolidColorBrush x:Key="CardBorder"                     Color="#252830" />
        <SolidColorBrush x:Key="PreviewSurfaceBackground"       Color="#111214" />
        <SolidColorBrush x:Key="PreviewSurfaceBorder"           Color="#252830" />
        <SolidColorBrush x:Key="PreviewEncoderOuterFill"        Color="#252830" />
        <SolidColorBrush x:Key="PreviewEncoderInnerFill"        Color="#1A1D20" />
        <SolidColorBrush x:Key="PreviewEncoderStroke"           Color="#5DCAA5" />
        <SolidColorBrush x:Key="PreviewEncoderActiveBackground" Color="#0D2E22" />

        <SolidColorBrush x:Key="ButtonBackground"               Color="#1A1D20" />
        <SolidColorBrush x:Key="ButtonHoverBackground"          Color="#252830" />
        <SolidColorBrush x:Key="ButtonPressedBackground"        Color="#111214" />
        <SolidColorBrush x:Key="ButtonForeground"               Color="#F2F2F2" />
        <SolidColorBrush x:Key="ButtonBorder"                   Color="#303540" />

        <SolidColorBrush x:Key="ListBackground"                 Color="#111214" />
        <SolidColorBrush x:Key="HeaderBackground"               Color="#111214" />
        <SolidColorBrush x:Key="HeaderForeground"               Color="#F2F2F2" />
        <SolidColorBrush x:Key="SelectedBackground"             Color="#0D2E22" />
        <SolidColorBrush x:Key="SelectedForeground"             Color="#5DCAA5" />
        <SolidColorBrush x:Key="InputBackground"                Color="#111214" />
        <SolidColorBrush x:Key="InputForeground"                Color="#F2F2F2" />
        <SolidColorBrush x:Key="PopupBackground"                Color="#1A1D20" />
        <SolidColorBrush x:Key="TabSelectedBackground"          Color="#1A1D20" />
        <SolidColorBrush x:Key="TabSelectedForeground"          Color="#F2F2F2" />
        <SolidColorBrush x:Key="TabUnselectedBackground"        Color="#111214" />
        <SolidColorBrush x:Key="TabUnselectedForeground"        Color="#7A7F88" />
        <SolidColorBrush x:Key="TabBorderBrush"                 Color="#252830" />
        <SolidColorBrush x:Key="ConnectionGoodForeground"       Color="#1D9E75" />
        <SolidColorBrush x:Key="ConnectionBadForeground"        Color="#E05A5A" />
        <SolidColorBrush x:Key="WarningForeground"              Color="#EF9F27" />
        <SolidColorBrush x:Key="WarningBannerBackground"        Color="#221800" />
        <SolidColorBrush x:Key="WarningBannerBorder"            Color="#3D2E00" />
        <SolidColorBrush x:Key="WarningBannerForeground"        Color="#FAC775" />
        <SolidColorBrush x:Key="UpdateBannerBackground"         Color="#0D1E1A" />
        <SolidColorBrush x:Key="UpdateBannerBorder"             Color="#143D2E" />
        <SolidColorBrush x:Key="UpdateBannerForeground"         Color="#5DCAA5" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource AppForeground}" />
        </Style>

        <Style TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource ButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource SelectedBackground}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource ButtonPressedBackground}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource SelectedBackground}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1D9E75" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#0F6E56" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="PrimaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Background" Value="#0F6E56" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Background" Value="#085041" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource AppForeground}" />
        </Style>

        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource AppForeground}" />
        </Style>

        <!-- Slim rounded progress bar — dark track, teal fill -->
        <Style TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ConnectionGoodForeground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border x:Name="PART_Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}" />
            <Setter Property="Padding" Value="5,3" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="Background" Value="{DynamicResource PopupBackground}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedForeground}" />
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedForeground}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="{x:Type ToggleButton}">
            <Border x:Name="ToggleBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1"
                            Background="{DynamicResource ButtonBackground}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,0,0,0">
                        <Path HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource ButtonForeground}"
                              Data="M 0 0 L 4 4 L 8 0 Z" />
                    </Border>
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder"
                            Property="BorderBrush"
                            Value="{DynamicResource SelectedBackground}" />
                </Trigger>

                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="ToggleBorder"
                            Property="BorderBrush"
                            Value="{DynamicResource SelectedBackground}" />
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder"
                            Property="Opacity"
                            Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}" />
            <Setter Property="Background" Value="{DynamicResource InputBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource {x:Type ComboBoxItem}}" />
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Template="{StaticResource ComboBoxToggleButtonTemplate}" />

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,3,32,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource PopupBackground}"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="0"
                                                  SnapsToDevicePixels="True"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup"
                                        Property="MinHeight"
                                        Value="30" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush"
                                        Value="{DynamicResource SelectedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{DynamicResource AppBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <DockPanel>
                            <!-- Tab strip — no chrome border, just the pills over app background -->
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource AppBackground}"
                                    Padding="0,0,0,8">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <!-- Tab content -->
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource TabUnselectedForeground}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedForeground}" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedForeground}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ListView}">
            <Setter Property="Background" Value="{DynamicResource ListBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
        </Style>

        <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="Background" Value="{DynamicResource ListBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppForeground}" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                                <Setter TargetName="RowBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource SelectedForeground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedForeground}" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SelectedForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource HeaderBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource HeaderForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder"
                                        Property="Background"
                                        Value="{DynamicResource HeaderBackground}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBorder"
                                        Property="Background"
                                        Value="{DynamicResource SelectedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Status bar docked to the bottom -->
        <Border DockPanel.Dock="Bottom"
                x:Name="StatusBar"
                BorderThickness="0,1,0,0"
                Padding="10,5"
                Background="{DynamicResource CardBackground}">
            <DockPanel>
                <Ellipse x:Name="StatusBarDot"
                         Width="10" Height="10"
                         Fill="{DynamicResource ConnectionBadForeground}"
                         Margin="0,0,6,0"
                         DockPanel.Dock="Left"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusBarConnectionText"
                           Text="Disconnected"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           DockPanel.Dock="Left" />
                <TextBlock x:Name="StatusBarProfileText"
                           Text=""
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           Foreground="{DynamicResource SecondaryForeground}"
                           DockPanel.Dock="Left" />
                <TextBlock x:Name="StatusBarFirmwareText"
                           Text=""
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryForeground}"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="PC Volume Controller Dashboard"
                           FontSize="26"
                           FontWeight="SemiBold" />
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="CloseAppButton"
                    Content="Shutdown App"
                    Width="110"
                    Height="34"
                    Margin="16,0,0,0"
                    VerticalAlignment="Top"
                    ToolTip="Exit the PC Volume Controller Dashboard"
                    Click="CloseAppButton_Click" />
        </Grid>

        <!-- Warning banner — shown when audio or serial errors occur -->
        <Border x:Name="WarningBanner"
                Grid.Row="1"
                Background="{DynamicResource WarningBannerBackground}"
                BorderBrush="{DynamicResource WarningBannerBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,8"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <Button x:Name="DismissWarningButton"
                        Content="✕"
                        Width="24" Height="24"
                        Padding="0"
                        DockPanel.Dock="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource WarningBannerForeground}"
                        Cursor="Hand"
                        ToolTip="Dismiss this warning"
                        Click="DismissWarningButton_Click" />
                <TextBlock x:Name="WarningBannerText"
                           Text=""
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource WarningBannerForeground}" />
            </DockPanel>
        </Border>

        <!-- Update available banner — shown when a newer release is detected on GitHub -->
        <Border x:Name="UpdateBanner"
                Grid.Row="2"
                Background="{DynamicResource UpdateBannerBackground}"
                BorderBrush="{DynamicResource UpdateBannerBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,8"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <Button x:Name="DismissUpdateBannerButton"
                        Content="✕"
                        Width="24" Height="24"
                        Padding="0"
                        DockPanel.Dock="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource UpdateBannerForeground}"
                        Cursor="Hand"
                        ToolTip="Dismiss this notification"
                        Click="DismissUpdateBanner_Click" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource UpdateBannerForeground}">
                    <Run Text="🔔 A new version is available: " />
                    <Run x:Name="UpdateBannerVersionRun" Text="v?.?" FontWeight="SemiBold" />
                    <Run Text=" — " />
                    <Hyperlink x:Name="UpdateBannerLink"
                               Foreground="{DynamicResource UpdateBannerForeground}"
                               RequestNavigate="UpdateBannerLink_RequestNavigate">View release notes</Hyperlink>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- VoiceMeeter offline banner — shown when in VM mode but VM is not running -->
        <Border x:Name="VoiceMeeterOfflineBanner"
                Grid.Row="3"
                Background="{DynamicResource WarningBannerBackground}"
                BorderBrush="{DynamicResource WarningBannerBorder}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,8"
                Visibility="Collapsed">
            <TextBlock Text="⚠ VoiceMeeter is not running. Start VoiceMeeter to restore encoder control. The dashboard will reconnect automatically."
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource WarningBannerForeground}" />
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="4">
            <TabItem Header="Audio">
                <Grid Margin="0,12,0,0" Background="{DynamicResource AppBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="COM Port:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />

                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      x:Name="ComPortComboBox"
                                      Height="30"
                                      Margin="0,0,8,0"
                                      ToolTip="Select the COM port your controller is connected to" />

                            <Button Grid.Row="0" Grid.Column="2"
                                    x:Name="RefreshPortsButton"
                                    Content="Refresh"
                                    Width="90"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    ToolTip="Refresh the list of available COM ports"
                                    Click="RefreshPortsButton_Click" />

                            <Button Grid.Row="0" Grid.Column="3"
                                    x:Name="ConnectButton"
                                    Content="Connect"
                                    Width="110"
                                    Height="30"
                                    Style="{StaticResource PrimaryButton}"
                                    ToolTip="Connect to or disconnect from the selected controller"
                                    Click="ConnectButton_Click" />

                            <TextBlock Grid.Row="0" Grid.Column="4"
                                       x:Name="ConnectionStatusTextBlock"
                                       Text="Disconnected"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ConnectionBadForeground}"
                                       Margin="16,0,0,0" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Controller:"
                                       VerticalAlignment="Center"
                                       Margin="0,10,8,0" />

                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Grid.ColumnSpan="4"
                                       x:Name="EspStatusTextBlock"
                                       Text="No device connected"
                                       VerticalAlignment="Center"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource SecondaryForeground}" />
                        </Grid>

                        <!-- Wrong-controller warning banner (hidden unless chip ID mismatch) -->
                        <Border x:Name="ChipIdMismatchBanner"
                                Visibility="Collapsed"
                                CornerRadius="4"
                                Padding="10,8"
                                Margin="0,10,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="⚠ "
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <Button Content="Forget &amp; re-pair"
                                            Height="26"
                                            Margin="8,0,4,0"
                                            ToolTip="Clear the paired controller ID and accept this device as the new controller"
                                            Click="ChipIdMismatch_ForgetAndRepair" />
                                    <Button Content="Dismiss"
                                            Height="26"
                                            Margin="0,0,0,0"
                                            ToolTip="Hide this warning for the current session"
                                            Click="ChipIdMismatch_Dismiss" />
                                </StackPanel>
                                <TextBlock x:Name="ChipIdMismatchMessageTextBlock"
                                           Text="Connected controller is different from the previously paired device."
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </DockPanel>
                        </Border>
                        </StackPanel>
                    </Border>

                    <!-- Profile bar -->
                    <Border Grid.Row="1"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Profile:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       DockPanel.Dock="Left" />
                            <ComboBox x:Name="ProfileComboBox"
                                      Width="180"
                                      Height="30"
                                      Margin="0,0,8,0"
                                      DockPanel.Dock="Left"
                                      ToolTip="Select an active channel mapping profile"
                                      SelectionChanged="ProfileComboBox_SelectionChanged" />
                            <Button x:Name="NewProfileButton"
                                    Content="_New"
                                    Width="60"
                                    Height="30"
                                    Margin="0,0,6,0"
                                    DockPanel.Dock="Left"
                                    Style="{StaticResource PrimaryButton}"
                                    ToolTip="Create a new channel mapping profile"
                                    Click="NewProfileButton_Click" />
                            <Button x:Name="RenameProfileButton"
                                    Content="Rename"
                                    Width="70"
                                    Height="30"
                                    Margin="0,0,6,0"
                                    DockPanel.Dock="Left"
                                    ToolTip="Rename the current profile"
                                    Click="RenameProfileButton_Click" />
                            <Button x:Name="DuplicateProfileButton"
                                    Content="Duplicate"
                                    Width="80"
                                    Height="30"
                                    Margin="0,0,6,0"
                                    DockPanel.Dock="Left"
                                    ToolTip="Duplicate the current profile with a new name"
                                    Click="DuplicateProfileButton_Click" />
                            <Button x:Name="DeleteProfileButton"
                                    Content="Delete"
                                    Width="65"
                                    Height="30"
                                    DockPanel.Dock="Left"
                                    ToolTip="Delete the current profile (cannot be undone)"
                                    Click="DeleteProfileButton_Click" />
                        </DockPanel>
                    </Border>

                    <!-- Output Devices cycle panel (v2.35) -->
                    <Border Grid.Row="2"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <DockPanel>
                            <TextBlock Text="Output Devices:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       DockPanel.Dock="Left"/>
                            <Button x:Name="RefreshOutputDevicesButton"
                                    Content="Refresh"
                                    Width="70" Height="26"
                                    DockPanel.Dock="Right"
                                    Margin="6,0,0,0"
                                    ToolTip="Re-scan available audio output devices"
                                    Click="RefreshOutputDevicesButton_Click"/>
                            <ListView x:Name="OutputDevicesListView"
                                      MaxHeight="80"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Cycle" Width="48">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IncludeInCycle, Mode=TwoWay}"
                                                              HorizontalAlignment="Center"
                                                              Checked="OutputDeviceInclude_Changed"
                                                              Unchecked="OutputDeviceInclude_Changed"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Device" Width="280" DisplayMemberBinding="{Binding FriendlyName}"/>
                                        <GridViewColumn Header="Active" Width="50" DisplayMemberBinding="{Binding DefaultIndicator}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.22*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="Channel Mapping"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="Saved app targets stay visible even when the app is not currently open."
                                               Foreground="{DynamicResource SecondaryForeground}"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap" />

                                    <!-- Row 0: channel selector + target assignment + Assign button -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Channel:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />

                                        <ComboBox Grid.Column="1"
                                                  x:Name="LogicalChannelComboBox"
                                                  Height="30"
                                                  Margin="0,0,12,0"
                                                  ToolTip="Select which encoder channel to configure"
                                                  SelectionChanged="LogicalChannelComboBox_SelectionChanged" />

                                        <TextBlock Grid.Column="2"
                                                   Text="Assign to:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />

                                        <ComboBox Grid.Column="3"
                                                  x:Name="ChannelTargetComboBox"
                                                  Height="30"
                                                  Margin="0,0,12,0"
                                                  ToolTip="Select the Windows audio session to assign to this channel"
                                                  DisplayMemberPath="Label" />

                                        <Button Grid.Column="4"
                                                x:Name="AssignChannelButton"
                                                Content="_Assign"
                                                Width="80"
                                                Height="30"
                                                Style="{StaticResource PrimaryButton}"
                                                ToolTip="Set this as the only app for this channel (replaces any existing pool)"
                                                Click="AssignChannelButton_Click" />

                                        <Button Grid.Column="5"
                                                x:Name="AddToPoolButton"
                                                Content="Add"
                                                Width="60"
                                                Height="30"
                                                Margin="4,0,0,0"
                                                ToolTip="Add this app to the channel's pool — the channel will watch all pooled apps and control whichever is running"
                                                Click="AddToPoolButton_Click" />
                                    </Grid>

                                    <!-- Row 1: OLED display name + Save Name button -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Display name:"
                                                   VerticalAlignment="Top"
                                                   Margin="0,6,8,0" />

                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBox x:Name="ChannelDisplayNameTextBox"
                                                     Height="30"
                                                     MaxLength="16"
                                                     ToolTip="Friendly name shown on the OLED display (max 16 characters)"
                                                     TextChanged="ChannelDisplayNameTextBox_TextChanged" />
                                            <TextBlock x:Name="DisplayNameCharCountTextBlock"
                                                       Text="0 / 16"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SecondaryForeground}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                x:Name="SaveDisplayNameButton"
                                                Content="Save Name"
                                                Width="90"
                                                Height="30"
                                                VerticalAlignment="Top"
                                                ToolTip="Save this display name to the selected channel"
                                                Click="SaveDisplayNameButton_Click" />
                                    </Grid>

                                    <!-- Row 2: multi-app pool chips (hidden when pool is empty) -->
                                    <Border x:Name="ChannelPoolBorder"
                                            Visibility="Collapsed"
                                            Margin="0,0,0,8"
                                            Padding="8,6"
                                            CornerRadius="4"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            Background="{DynamicResource ListBackground}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="App pool:"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       FontWeight="SemiBold" />
                                            <ItemsControl x:Name="ChannelPoolItemsControl">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,4"
                                                                Padding="6,2"
                                                                CornerRadius="4"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource CardBorder}"
                                                                Background="{DynamicResource ButtonBackground}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Label}"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           Margin="0,0,4,0" />
                                                                <Button Content="×"
                                                                        Tag="{Binding Key}"
                                                                        Width="16"
                                                                        Height="16"
                                                                        Padding="0"
                                                                        FontSize="10"
                                                                        VerticalAlignment="Center"
                                                                        ToolTip="Remove from pool"
                                                                        Click="RemoveFromChannelPool_Click" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>

                                <ListView x:Name="ChannelMappingsListView"
                                          HorizontalContentAlignment="Stretch"
                                          VerticalContentAlignment="Stretch"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          SelectionChanged="ChannelMappingsListView_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAppOffline}" Value="True">
                                                    <Setter Property="Opacity" Value="0.45" />
                                                    <Setter Property="FontStyle" Value="Italic" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Ch" Width="42" DisplayMemberBinding="{Binding ChannelDisplay}" />
                                            <GridViewColumn Header="Display Name" Width="135" DisplayMemberBinding="{Binding DisplayLabel}" />
                                            <GridViewColumn Header="Assigned Target" Width="145" DisplayMemberBinding="{Binding AssignedLabel}" />
                                            <GridViewColumn Header="Volume" Width="80">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="3" />
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Text="{Binding VolumeDisplay}" FontSize="11" />
                                                            <ProgressBar Grid.Row="1"
                                                                         Value="{Binding Volume}"
                                                                         Minimum="0" Maximum="100"
                                                                         Height="3"
                                                                         Background="Transparent"
                                                                         BorderThickness="0"
                                                                         Foreground="{DynamicResource ConnectionGoodForeground}"
                                                                         Margin="0,1,0,0" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Mute" Width="60" DisplayMemberBinding="{Binding MuteDisplay}" />
                                            <GridViewColumn Header="Status" Width="130" DisplayMemberBinding="{Binding Status}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Focusable="False">
                                <StackPanel>
                                    <TextBlock Text="Selected Channel"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <TextBlock x:Name="SelectedTargetTextBlock"
                                               Text="Channel 1 - Master"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Margin="0,14,0,4" />

                                    <TextBlock x:Name="SelectedTargetDetailTextBlock"
                                               Text="Windows master volume"
                                               Foreground="{DynamicResource SecondaryForeground}"
                                               Margin="0,0,0,14" />

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Grid.Column="0"
                                                     x:Name="SelectedVolumeProgressBar"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Height="8"
                                                     Value="0"
                                                     Margin="0,0,12,0" />

                                        <TextBlock Grid.Column="1"
                                                   x:Name="SelectedVolumeTextBlock"
                                                   Text="0%"
                                                   Width="52"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold" />
                                    </Grid>

                                    <TextBlock x:Name="SelectedMuteTextBlock"
                                               Text="Mute: No"
                                               Margin="0,0,0,14" />

                                    <Border BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="Per-Channel Controls"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />

                                            <TextBlock Text="These settings apply to the currently selected physical encoder/channel."
                                                       Foreground="{DynamicResource SecondaryForeground}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />

                                            <Grid MaxWidth="360">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Short press:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <ComboBox Grid.Column="1"
                                                          x:Name="ChannelButtonActionComboBox"
                                                          Height="30"
                                                          ToolTip="Action triggered when the encoder button is pressed briefly"
                                                          SelectionChanged="ChannelButtonActionComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Select next channel" />
                                                    <ComboBoxItem Content="Toggle assigned mute" />
                                                    <ComboBoxItem Content="No action" />
                                                    <ComboBoxItem Content="Next profile" />
                                                    <ComboBoxItem Content="Cycle output device" />
                                                    <ComboBoxItem Content="Apply preset 1" />
                                                    <ComboBoxItem Content="Apply preset 2" />
                                                    <ComboBoxItem Content="Apply preset 3" />
                                                    <ComboBoxItem Content="Play / Pause" />
                                                    <ComboBoxItem Content="Next track" />
                                                    <ComboBoxItem Content="Previous track" />
                                                    <ComboBoxItem Content="Stop" />
                                                </ComboBox>
                                            </Grid>

                                            <Grid MaxWidth="360" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Long press:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <ComboBox Grid.Column="1"
                                                          x:Name="ChannelLongPressActionComboBox"
                                                          Height="30"
                                                          ToolTip="Action triggered when the encoder button is held for ~1 second"
                                                          SelectionChanged="ChannelLongPressActionComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Toggle assigned mute" />
                                                    <ComboBoxItem Content="No action" />
                                                    <ComboBoxItem Content="Next profile" />
                                                    <ComboBoxItem Content="Cycle output device" />
                                                    <ComboBoxItem Content="Apply preset 1" />
                                                    <ComboBoxItem Content="Apply preset 2" />
                                                    <ComboBoxItem Content="Apply preset 3" />
                                                    <ComboBoxItem Content="Play / Pause" />
                                                    <ComboBoxItem Content="Next track" />
                                                    <ComboBoxItem Content="Previous track" />
                                                    <ComboBoxItem Content="Stop" />
                                                </ComboBox>
                                            </Grid>

                                            <Grid MaxWidth="360" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Double press:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <ComboBox Grid.Column="1"
                                                          x:Name="ChannelDoublePressActionComboBox"
                                                          Height="30"
                                                          ToolTip="Action triggered when the encoder button is pressed twice quickly"
                                                          SelectionChanged="ChannelDoublePressActionComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Toggle assigned mute" />
                                                    <ComboBoxItem Content="No action" />
                                                    <ComboBoxItem Content="Next profile" />
                                                    <ComboBoxItem Content="Cycle output device" />
                                                    <ComboBoxItem Content="Apply preset 1" />
                                                    <ComboBoxItem Content="Apply preset 2" />
                                                    <ComboBoxItem Content="Apply preset 3" />
                                                    <ComboBoxItem Content="Play / Pause" />
                                                    <ComboBoxItem Content="Next track" />
                                                    <ComboBoxItem Content="Previous track" />
                                                    <ComboBoxItem Content="Stop" />
                                                </ComboBox>
                                            </Grid>

                                            <Grid MaxWidth="360" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="OLED mode:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <ComboBox Grid.Column="1"
                                                          x:Name="ChannelOledModeComboBox"
                                                          Height="30"
                                                          ToolTip="What to show on the OLED display for this channel"
                                                          SelectionChanged="ChannelOledModeComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Use global default" />
                                                    <ComboBoxItem Content="App name + volume" />
                                                    <ComboBoxItem Content="Large volume number" />
                                                    <ComboBoxItem Content="Mute status" />
                                                    <ComboBoxItem Content="App name only" />
                                                    <ComboBoxItem Content="Volume bar" />
                                                </ComboBox>
                                            </Grid>

                                            <Grid MaxWidth="360" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="App offline:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <ComboBox Grid.Column="1" x:Name="ChannelRebindComboBox" Height="30"
                                                          ToolTip="What to do when this channel's assigned app is not running"
                                                          SelectionChanged="ChannelRebindComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Show Inactive" />
                                                    <ComboBoxItem Content="Do Nothing" />
                                                </ComboBox>
                                            </Grid>

                                            <Grid MaxWidth="360" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Sensitivity:"
                                                           VerticalAlignment="Top"
                                                           Margin="0,6,8,0" />
                                                <StackPanel Grid.Column="1">
                                                    <CheckBox x:Name="PerChannelSensitivityUseGlobalCheckBox"
                                                              Content="Use global"
                                                              Margin="0,4,0,4"
                                                              ToolTip="Use the global encoder sensitivity setting for this channel"
                                                              Checked="PerChannelSensitivityUseGlobalCheckBox_Changed"
                                                              Unchecked="PerChannelSensitivityUseGlobalCheckBox_Changed" />
                                                    <Grid x:Name="PerChannelSensitivityPanel" Visibility="Collapsed">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="50" />
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Grid.Column="0"
                                                                x:Name="PerChannelSensitivitySlider"
                                                                Minimum="0"
                                                                Maximum="500"
                                                                TickFrequency="10"
                                                                IsSnapToTickEnabled="False"
                                                                ToolTip="Per-channel encoder sensitivity (overrides the global setting)"
                                                                ValueChanged="PerChannelSensitivitySlider_ValueChanged"
                                                                PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                                PreviewMouseMove="Slider_PreviewMouseMove"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1"
                                                                   x:Name="PerChannelSensitivityValueTextBlock"
                                                                   Text="100%"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="4,0,0,0" />
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Mute hotkey -->
                                            <Grid MaxWidth="360" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="50" />
                                                    <ColumnDefinition Width="50" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Mute hotkey:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="1"
                                                           x:Name="ChannelMuteHotkeyTextBlock"
                                                           Text="(unassigned)"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SecondaryForeground}" />
                                                <Button Grid.Column="2"
                                                        Content="Set"
                                                        Height="26"
                                                        Margin="4,0,2,0"
                                                        ToolTip="Assign a keyboard shortcut to toggle mute for this channel"
                                                        Click="ChannelMuteHotkey_Set" />
                                                <Button Grid.Column="3"
                                                        Content="Clear"
                                                        Height="26"
                                                        Margin="2,0,0,0"
                                                        Click="ChannelMuteHotkey_Clear" />
                                            </Grid>

                                            <!-- Volume Limits -->
                                            <Separator Margin="0,12,0,8"/>
                                            <TextBlock Text="Volume Limits"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Clamp this channel's volume to the selected range."
                                                       Foreground="{DynamicResource SecondaryForeground}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>

                                            <!-- Min volume row -->
                                            <Grid MaxWidth="360" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="42" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Min volume:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <Slider Grid.Column="1"
                                                        x:Name="ChannelMinVolumeSlider"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        ToolTip="Minimum allowed volume for this channel (0–100%)"
                                                        ValueChanged="ChannelMinVolumeSlider_ValueChanged"
                                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           x:Name="ChannelMinVolumeValueTextBlock"
                                                           Text="0%"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Margin="4,0,0,0" />
                                            </Grid>

                                            <!-- Max volume row -->
                                            <Grid MaxWidth="360" Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="42" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Max volume:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <Slider Grid.Column="1"
                                                        x:Name="ChannelMaxVolumeSlider"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        ToolTip="Maximum allowed volume for this channel (0–100%)"
                                                        ValueChanged="ChannelMaxVolumeSlider_ValueChanged"
                                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           x:Name="ChannelMaxVolumeValueTextBlock"
                                                           Text="100%"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Margin="4,0,0,0" />
                                            </Grid>

                                            <!-- Volume Presets -->
                                            <Separator Margin="0,12,0,8"/>
                                            <TextBlock Text="Volume Presets"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="Assign these as button actions: Apply preset 1 / 2 / 3."
                                                       Foreground="{DynamicResource SecondaryForeground}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>

                                            <!-- Preset 1 -->
                                            <Grid MaxWidth="360" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="62"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Preset 1:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         x:Name="Preset1NameTextBox"
                                                         Height="28"
                                                         MaxLength="16"
                                                         Margin="0,0,8,0"
                                                         ToolTip="Preset 1 name (optional)"
                                                         LostFocus="PresetName_LostFocus"
                                                         Tag="0"/>
                                                <Slider Grid.Column="2"
                                                        x:Name="Preset1VolumeSlider"
                                                        Minimum="0" Maximum="100"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Preset 1 volume (0–100%)"
                                                        ValueChanged="PresetVolume_ValueChanged"
                                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                                        LostMouseCapture="Slider_LostMouseCapture"
                                                        Tag="0"/>
                                                <TextBlock Grid.Column="3"
                                                           x:Name="Preset1VolumeValueTextBlock"
                                                           Text="25%"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Margin="4,0,0,0"/>
                                            </Grid>

                                            <!-- Preset 2 -->
                                            <Grid MaxWidth="360" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="62"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Preset 2:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         x:Name="Preset2NameTextBox"
                                                         Height="28"
                                                         MaxLength="16"
                                                         Margin="0,0,8,0"
                                                         ToolTip="Preset 2 name (optional)"
                                                         LostFocus="PresetName_LostFocus"
                                                         Tag="1"/>
                                                <Slider Grid.Column="2"
                                                        x:Name="Preset2VolumeSlider"
                                                        Minimum="0" Maximum="100"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Preset 2 volume (0–100%)"
                                                        ValueChanged="PresetVolume_ValueChanged"
                                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                                        LostMouseCapture="Slider_LostMouseCapture"
                                                        Tag="1"/>
                                                <TextBlock Grid.Column="3"
                                                           x:Name="Preset2VolumeValueTextBlock"
                                                           Text="50%"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Margin="4,0,0,0"/>
                                            </Grid>

                                            <!-- Preset 3 -->
                                            <Grid MaxWidth="360" Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="62"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Preset 3:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Grid.Column="1"
                                                         x:Name="Preset3NameTextBox"
                                                         Height="28"
                                                         MaxLength="16"
                                                         Margin="0,0,8,0"
                                                         ToolTip="Preset 3 name (optional)"
                                                         LostFocus="PresetName_LostFocus"
                                                         Tag="2"/>
                                                <Slider Grid.Column="2"
                                                        x:Name="Preset3VolumeSlider"
                                                        Minimum="0" Maximum="100"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="False"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Preset 3 volume (0–100%)"
                                                        ValueChanged="PresetVolume_ValueChanged"
                                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                                        LostMouseCapture="Slider_LostMouseCapture"
                                                        Tag="2"/>
                                                <TextBlock Grid.Column="3"
                                                           x:Name="Preset3VolumeValueTextBlock"
                                                           Text="75%"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           Margin="4,0,0,0"/>
                                            </Grid>

                                            <!-- Channel Linking -->
                                            <Separator Margin="0,12,0,8"/>
                                            <TextBlock Text="Channel Linking"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Channels sharing the same group name move together when an encoder is turned."
                                                       Foreground="{DynamicResource SecondaryForeground}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>
                                            <Grid MaxWidth="360">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="86" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Link group:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0" />
                                                <TextBox Grid.Column="1"
                                                         x:Name="ChannelLinkGroupTextBox"
                                                         Height="28"
                                                         MaxLength="32"
                                                         ToolTip="Type a group name (e.g. A, music) to gang this channel with others that share the same name. Leave empty to unlink."
                                                         LostFocus="ChannelLinkGroup_LostFocus" />
                                                <Button Grid.Column="2"
                                                        Content="Clear"
                                                        Height="28"
                                                        Width="54"
                                                        Margin="4,0,0,0"
                                                        ToolTip="Remove this channel from its link group"
                                                        Click="ChannelLinkGroup_Clear" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,0,0,18">
                                        <Button x:Name="PreviousChannelButton"
                                                Content="Prev Channel"
                                                Width="110"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                ToolTip="Switch OLED selection to the previous channel"
                                                Click="PreviousChannelButton_Click" />

                                        <Button x:Name="NextChannelButton"
                                                Content="Next Channel"
                                                Width="110"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                ToolTip="Switch OLED selection to the next channel"
                                                Click="NextChannelButton_Click" />

                                        <Button x:Name="VolumeDownButton"
                                                Content="Volume -"
                                                Width="90"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                ToolTip="Decrease the volume of the selected channel"
                                                Click="VolumeDownButton_Click" />

                                        <Button x:Name="VolumeUpButton"
                                                Content="Volume +"
                                                Width="90"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                ToolTip="Increase the volume of the selected channel"
                                                Click="VolumeUpButton_Click" />

                                        <Button x:Name="MuteButton"
                                                Content="Mute / Unmute"
                                                Width="130"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                ToolTip="Toggle mute for the selected channel"
                                                Click="MuteButton_Click" />
                                    </WrapPanel>

                                    <Separator Margin="0,0,0,14" />

                                    <TextBlock Text="Detected Audio Sessions"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <TextBlock Text="Includes active sessions and saved targets waiting for their app."
                                               Foreground="{DynamicResource SecondaryForeground}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,8" />

                                    <Button x:Name="RefreshSessionsButton"
                                            Content="Refresh Sessions"
                                            Width="140"
                                            Height="30"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,8"
                                            ToolTip="Manually refresh the list of Windows audio sessions"
                                            Click="RefreshSessionsButton_Click" />
                                    <ListView x:Name="AudioSessionsListView"
                                              Margin="0,0,0,0"
                                              MinHeight="120"
                                              MaxHeight="280"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Target" Width="130" DisplayMemberBinding="{Binding Label}" />
                                                <GridViewColumn Header="Vol" Width="60" DisplayMemberBinding="{Binding VolumeDisplay}" />
                                                <GridViewColumn Header="Mute" Width="60" DisplayMemberBinding="{Binding MuteDisplay}" />
                                                <GridViewColumn Header="State" Width="110" DisplayMemberBinding="{Binding State}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Empty state — shown when controller is not connected -->
                        <Border x:Name="AudioEmptyStatePanel"
                                Grid.Column="0" Grid.ColumnSpan="3"
                                Background="{DynamicResource AppBackground}"
                                Panel.ZIndex="10"
                                Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔌"
                                           FontSize="48"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12" />
                                <TextBlock Text="Controller not connected"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Connect your PC Volume Controller via USB, then use the Connect button above."
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           MaxWidth="380"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

            </TabItem>

            <TabItem Header="OLED Setup">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="OLED Display Settings"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="These settings drive the dashboard controller preview and are sent to the ESP32 when you save OLED setup."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Display mode:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="1" x:Name="DisplayModeComboBox" Height="30" SelectionChanged="DisplayModeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="App name + volume" />
                                        <ComboBoxItem Content="Large volume number" />
                                        <ComboBoxItem Content="Mute status" />
                                        <ComboBoxItem Content="App/device name" />
                                        <ComboBoxItem Content="Simple bar/percentage view" />
                                    </ComboBox>
                                </Grid>

                                <TextBlock x:Name="OledBrightnessValueTextBlock"
                                           Text="Brightness: 80%"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <Slider x:Name="OledBrightnessSlider"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="False"
                                        ToolTip="OLED display brightness (0% = off, 100% = maximum)"
                                        ValueChanged="OledBrightnessSlider_ValueChanged"
                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="Slider_LostMouseCapture"
                                        MaxWidth="420"
                                        Margin="0,0,0,10" />

                                <TextBlock x:Name="OledSleepTimeoutValueTextBlock"
                                           Text="Disconnected sleep timeout: 2 minute(s)"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <Slider x:Name="OledSleepTimeoutSlider"
                                        Minimum="1"
                                        Maximum="60"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ToolTip="How long to wait before sleeping the display when the controller is disconnected"
                                        ValueChanged="OledSleepTimeoutSlider_ValueChanged"
                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="Slider_LostMouseCapture"
                                        MaxWidth="420"
                                        Margin="0,0,0,14" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Connected idle action:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="1" x:Name="OledConnectedIdleActionComboBox" Height="30" SelectionChanged="OledConnectedIdleActionComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Turn off display" />
                                        <ComboBoxItem Content="Dim brightness to 10%" />
                                        <ComboBoxItem Content="Dim brightness to 20%" />
                                        <ComboBoxItem Content="Dim brightness to 30%" />
                                        <ComboBoxItem Content="Dim brightness to 40%" />
                                        <ComboBoxItem Content="Dim brightness to 50%" />
                                        <ComboBoxItem Content="Dim brightness to 60%" />
                                        <ComboBoxItem Content="Dim brightness to 70%" />
                                    </ComboBox>
                                </Grid>

                                <TextBlock x:Name="OledConnectedIdleTimeoutValueTextBlock"
                                           Text="Connected idle timeout: 10 minute(s)"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <Slider x:Name="OledConnectedIdleTimeoutSlider"
                                        Minimum="1"
                                        Maximum="60"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ToolTip="How long to wait before dimming/turning off the display when idle"
                                        ValueChanged="OledConnectedIdleTimeoutSlider_ValueChanged"
                                        PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="Slider_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="Slider_LostMouseCapture"
                                        MaxWidth="420"
                                        Margin="0,0,0,14" />

                                <CheckBox x:Name="OledAntiBurnInCheckBox"
                                          Content="Enable anti-burn-in pixel shifting"
                                          IsChecked="True"
                                          ToolTip="Shifts pixels slightly over time to prevent OLED burn-in"
                                          Checked="OledAntiBurnInCheckBox_Changed"
                                          Unchecked="OledAntiBurnInCheckBox_Changed"
                                          Margin="0,0,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Whole Controller Preview" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="This preview shows the full six-channel controller layout, with the six OLEDs across the top and the six encoder positions underneath. Each OLED still renders a 128x64 logical canvas, scaled up on screen for readability." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,8" />
                                <TextBlock x:Name="OledPreviewModeTextBlock" Text="Preview mode: App name + volume" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,10" />

                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <Border BorderThickness="1" CornerRadius="10" Padding="18" Background="{DynamicResource PreviewSurfaceBackground}" BorderBrush="{DynamicResource PreviewSurfaceBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <UniformGrid Grid.Row="0" Columns="6" Rows="1" Margin="0,0,0,18">
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock x:Name="OledPreview1Title" Text="OLED 1" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                                        <Image x:Name="OledPreview1Image"
                                                               Width="192" Height="96"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock x:Name="OledPreview2Title" Text="OLED 2" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                                        <Image x:Name="OledPreview2Image"
                                                               Width="192" Height="96"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock x:Name="OledPreview3Title" Text="OLED 3" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                                        <Image x:Name="OledPreview3Image"
                                                               Width="192" Height="96"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock x:Name="OledPreview4Title" Text="OLED 4" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                                        <Image x:Name="OledPreview4Image"
                                                               Width="192" Height="96"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock x:Name="OledPreview5Title" Text="OLED 5" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                                        <Image x:Name="OledPreview5Image"
                                                               Width="192" Height="96"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock x:Name="OledPreview6Title" Text="OLED 6" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                                        <Image x:Name="OledPreview6Image"
                                                               Width="192" Height="96"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Border>
                                                </StackPanel>
                                            </UniformGrid>

                                            <UniformGrid Grid.Row="1" Columns="6" Rows="1">
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock Text="Encoder 1" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />
                                                    <Border x:Name="EncoderPreview1Highlight" CornerRadius="8" BorderThickness="2" BorderBrush="{DynamicResource CardBorder}" Background="Transparent" Padding="4">
                                                        <Grid Width="86" Height="86">
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderOuterFill}" StrokeThickness="1.2" Margin="9" />
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderInnerFill}" StrokeThickness="1.2" Margin="17" />
                                                        <Line X1="43" Y1="4" X2="43" Y2="22" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="43" Y1="64" X2="43" Y2="82" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="4" Y1="43" X2="22" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="64" Y1="43" X2="82" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <TextBlock Text="+" FontSize="26" Foreground="{DynamicResource PreviewEncoderStroke}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock Text="Encoder 2" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />
                                                    <Border x:Name="EncoderPreview2Highlight" CornerRadius="8" BorderThickness="2" BorderBrush="{DynamicResource CardBorder}" Background="Transparent" Padding="4">
                                                        <Grid Width="86" Height="86">
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderOuterFill}" StrokeThickness="1.2" Margin="9" />
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderInnerFill}" StrokeThickness="1.2" Margin="17" />
                                                        <Line X1="43" Y1="4" X2="43" Y2="22" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="43" Y1="64" X2="43" Y2="82" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="4" Y1="43" X2="22" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="64" Y1="43" X2="82" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <TextBlock Text="+" FontSize="26" Foreground="{DynamicResource PreviewEncoderStroke}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock Text="Encoder 3" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />
                                                    <Border x:Name="EncoderPreview3Highlight" CornerRadius="8" BorderThickness="2" BorderBrush="{DynamicResource CardBorder}" Background="Transparent" Padding="4">
                                                        <Grid Width="86" Height="86">
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderOuterFill}" StrokeThickness="1.2" Margin="9" />
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderInnerFill}" StrokeThickness="1.2" Margin="17" />
                                                        <Line X1="43" Y1="4" X2="43" Y2="22" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="43" Y1="64" X2="43" Y2="82" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="4" Y1="43" X2="22" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <Line X1="64" Y1="43" X2="82" Y2="43" Stroke="{DynamicResource PreviewEncoderStroke}" StrokeThickness="1" />
                                                        <TextBlock Text="+" FontSize="26" Foreground="{DynamicResource PreviewEncoderStroke}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Center" Margin="6,0">
                                                    <TextBlock Text="Encoder 4" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,6" />
                                                    <Border x:Name="EncoderPreview4Highlight" CornerRadius="8" BorderThickness="2" BorderBrush="{DynamicResource CardBorder}" Background="Transparent" Padding="4">
                                                        <Grid Width="86" Height="86">
                                                        <Ellipse Stroke="{DynamicResource PreviewEncoderStroke}" Fill="{DynamicResource PreviewEncoderOuterFill}" StrokeThickness="1.2" Margin="9" />
