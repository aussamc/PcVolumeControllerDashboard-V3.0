                                           Text="Paired controller: (none)"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap" />
                                <Button x:Name="ForgetControllerButton"
                                        Content="Forget controller"
                                        Width="160"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        ToolTip="Clear the paired controller chip ID so the next connection auto-pairs with any controller"
                                        Click="ForgetControllerButton_Click" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Audio Backend"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Choose how the dashboard reads and writes audio volume. Switching mode clears all channel assignments in every profile."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />

                                <RadioButton x:Name="WasapiRadioButton"
                                             Content="WASAPI (Windows audio sessions — default)"
                                             GroupName="AudioBackendGroup"
                                             Margin="0,0,0,6"
