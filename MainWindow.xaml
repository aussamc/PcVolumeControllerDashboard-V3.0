                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Global Hotkeys"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="These hotkeys work system-wide even when the dashboard is minimized. All hotkeys are unassigned by default."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>

                                <!-- Row template: Action | Current binding | [Set] [Clear] -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Master volume up:" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="HotkeyMasterVolUpTextBlock" Text="(unassigned)" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}"/>
                                    <Button Grid.Column="2" Content="Set" Height="26" Margin="4,0,2,0" Click="HotkeyMasterVolUp_Set"/>
                                    <Button Grid.Column="3" Content="Clear" Height="26" Margin="2,0,0,0" Click="HotkeyMasterVolUp_Clear"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Master volume down:" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="HotkeyMasterVolDownTextBlock" Text="(unassigned)" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}"/>
                                    <Button Grid.Column="2" Content="Set" Height="26" Margin="4,0,2,0" Click="HotkeyMasterVolDown_Set"/>
                                    <Button Grid.Column="3" Content="Clear" Height="26" Margin="2,0,0,0" Click="HotkeyMasterVolDown_Clear"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Toggle master mute:" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="HotkeyToggleMasterMuteTextBlock" Text="(unassigned)" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}"/>
                                    <Button Grid.Column="2" Content="Set" Height="26" Margin="4,0,2,0" Click="HotkeyToggleMasterMute_Set"/>
                                    <Button Grid.Column="3" Content="Clear" Height="26" Margin="2,0,0,0" Click="HotkeyToggleMasterMute_Clear"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Next profile:" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="HotkeyCycleNextProfileTextBlock" Text="(unassigned)" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}"/>
                                    <Button Grid.Column="2" Content="Set" Height="26" Margin="4,0,2,0" Click="HotkeyCycleNextProfile_Set"/>
                                    <Button Grid.Column="3" Content="Clear" Height="26" Margin="2,0,0,0" Click="HotkeyCycleNextProfile_Clear"/>
                                </Grid>

                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Show dashboard:" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="HotkeyShowDashboardTextBlock" Text="(unassigned)" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryForeground}"/>
                                    <Button Grid.Column="2" Content="Set" Height="26" Margin="4,0,2,0" Click="HotkeyShowDashboard_Set"/>
                                    <Button Grid.Column="3" Content="Clear" Height="26" Margin="2,0,0,0" Click="HotkeyShowDashboard_Clear"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Encoder Sensitivity"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Controls how much the volume changes for each encoder click. 50% is the default; higher values allow much faster changes."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10" />

                                <Grid MaxWidth="420">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Slider Grid.Row="0"
                                            x:Name="EncoderSensitivitySlider"
                                            Minimum="0"
                                            Maximum="500"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="False"
                                            ToolTip="Global encoder sensitivity — how much volume changes per click (50% is default)"
                                            ValueChanged="EncoderSensitivitySlider_ValueChanged"
                                            PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="Slider_PreviewMouseMove"
                                            PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="Slider_LostMouseCapture"
                                            MaxWidth="420" />

                                    <Grid Grid.Row="1" Margin="0,2,0,0">
                                        <TextBlock Text="0%" HorizontalAlignment="Left" />
                                        <TextBlock Text="500%" HorizontalAlignment="Right" />
                                    </Grid>
                                </Grid>

                                <TextBlock x:Name="EncoderSensitivityValueTextBlock"
                                           Text="Sensitivity: 50%"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Encoder Feel"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="Volume acceleration scales the volume step when you turn the encoder quickly. Volume smoothing eases the volume to its target over a short time rather than jumping instantly."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           Margin="0,0,0,12" />

                                <!-- Acceleration -->
                                <CheckBox x:Name="AccelerationEnabledCheckBox"
                                          Content="Enable volume acceleration"
                                          Margin="0,0,0,8"
                                          ToolTip="Scale the volume step size when turning the encoder quickly"
                                          Checked="AccelerationEnabledCheckBox_Changed"
                                          Unchecked="AccelerationEnabledCheckBox_Changed" />

                                <Grid Margin="0,0,0,16" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Acceleration preset:"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              x:Name="AccelerationPresetComboBox"
                                              Height="30"
                                              SelectionChanged="AccelerationPresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Light" />
                                        <ComboBoxItem Content="Medium" />
                                        <ComboBoxItem Content="Aggressive" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>
                                </Grid>

                                <!-- Custom acceleration tuning panel — visible only when "Custom" preset is selected -->
                                <StackPanel x:Name="AccelCustomPanel"
                                            Margin="0,8,0,4"
                                            Visibility="Collapsed">

                                    <TextBlock Text="Custom acceleration tuning"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />

                                    <!-- Speed threshold -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Speed threshold:" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                x:Name="AccelThresholdSlider"
                                                Minimum="20" Maximum="250"
                                                TickFrequency="10" IsSnapToTickEnabled="True"
                                                ValueChanged="AccelThresholdSlider_ValueChanged"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" x:Name="AccelThresholdLabel"
                                                   Text="150 ms" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Turn interval below which acceleration starts. Higher = kicks in earlier."
                                               FontSize="11" Opacity="0.6" Margin="170,0,0,8" TextWrapping="Wrap" />

                                    <!-- Max multiplier -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Max multiplier:" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                x:Name="AccelMaxMultiplierSlider"
                                                Minimum="1.5" Maximum="8.0"
                                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                                ValueChanged="AccelMaxMultiplierSlider_ValueChanged"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" x:Name="AccelMaxMultiplierLabel"
                                                   Text="8.0×" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Maximum step size boost when turning at full speed."
                                               FontSize="11" Opacity="0.6" Margin="170,0,0,8" TextWrapping="Wrap" />

                                    <!-- Curve exponent -->
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Curve shape:" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                x:Name="AccelCurveSlider"
                                                Minimum="0.3" Maximum="2.5"
                                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                ValueChanged="AccelCurveSlider_ValueChanged"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" x:Name="AccelCurveLabel"
                                                   Text="Early" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="Early/Soft = acceleration builds quickly; Linear = even ramp; Late/Sharp = boost only at max speed."
                                               FontSize="11" Opacity="0.6" Margin="170,0,0,8" TextWrapping="Wrap" />

                                    <!-- Live preview -->
                                    <TextBlock x:Name="AccelPreviewLabel"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Margin="0,0,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Smoothing -->
                                <CheckBox x:Name="VolumeSmoothingEnabledCheckBox"
                                          Content="Enable volume smoothing"
                                          Margin="0,0,0,8"
                                          ToolTip="Ease volume changes smoothly over a short time instead of jumping instantly"
                                          Checked="VolumeSmoothingEnabledCheckBox_Changed"
                                          Unchecked="VolumeSmoothingEnabledCheckBox_Changed" />

                                <Grid HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Smoothing speed:"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1"
                                              x:Name="VolumeSmoothingSpeedComboBox"
                                              Height="30"
                                              SelectionChanged="VolumeSmoothingSpeedComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Fast (~60 ms)" />
                                        <ComboBoxItem Content="Normal (~100 ms)" />
                                        <ComboBoxItem Content="Slow (~150 ms)" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Style Settings"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <RadioButton x:Name="ThemeFollowSystemRadioButton"
                                             Content="Follow System"
                                             GroupName="ThemeMode"
                                             Margin="0,0,0,8"
                                             Checked="ThemeRadioButton_Checked" />

                                <RadioButton x:Name="ThemeLightRadioButton"
                                             Content="Light Mode"
                                             GroupName="ThemeMode"
                                             Margin="0,0,0,8"
                                             Checked="ThemeRadioButton_Checked" />

                                <RadioButton x:Name="ThemeDarkRadioButton"
                                             Content="Dark Mode"
                                             GroupName="ThemeMode"
                                             Margin="0,0,0,8"
                                             Checked="ThemeRadioButton_Checked" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Volume Overlay"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Shows the channel name and volume level on-screen when you turn an encoder knob."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <CheckBox x:Name="OverlayEnabledCheckBox"
                                          Content="Show volume overlay when encoder turns"
                                          Margin="0,0,0,10"
                                          ToolTip="Display an on-screen volume indicator when an encoder is turned"
                                          Checked="OverlayEnabledCheckBox_Changed"
                                          Unchecked="OverlayEnabledCheckBox_Changed"/>

                                <Grid HorizontalAlignment="Left" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Screen position:"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              x:Name="OverlayPositionComboBox"
                                              Height="30"
                                              ToolTip="Where on the screen the volume overlay appears"
                                              SelectionChanged="OverlayPositionComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Top Left"    Tag="TopLeft"/>
                                        <ComboBoxItem Content="Top Center"  Tag="TopCenter"/>
                                        <ComboBoxItem Content="Top Right"   Tag="TopRight"/>
                                        <ComboBoxItem Content="Bottom Left"  Tag="BottomLeft"/>
                                        <ComboBoxItem Content="Bottom Center" Tag="BottomCenter"/>
                                        <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                                    </ComboBox>
                                </Grid>

                                <Grid HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Dismiss after:"
                                               VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1"
                                            x:Name="OverlayTimeoutSlider"
                                            Minimum="1" Maximum="8"
                                            TickFrequency="0.5"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            ToolTip="How many seconds the overlay stays visible before fading out"
                                            ValueChanged="OverlayTimeoutSlider_ValueChanged"
                                            PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="Slider_PreviewMouseMove"
                                            PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                            LostMouseCapture="Slider_LostMouseCapture"/>
                                    <TextBlock Grid.Column="2"
                                               x:Name="OverlayTimeoutValueTextBlock"
                                               Text="2.5 s"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               MinWidth="36"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Device Diagnostics"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock x:Name="DiagConnectionTextBlock" Text="ESP32 connection: Disconnected" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagComPortTextBlock" Text="COM port: --" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagLastHeartbeatTextBlock" Text="Last message: --" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagFirmwareTextBlock" Text="Firmware: Unknown" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagProtocolTextBlock" Text="Protocol: Unknown / Required 1.3" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagProtocolStatusTextBlock" Text="Protocol status: Waiting for ESP32" Margin="0,0,0,4" />
                                <TextBlock x:Name="DiagLastMessageTextBlock" Text="Last ESP32 message: --" Margin="0,0,0,4" TextWrapping="Wrap" />
                                <TextBlock x:Name="DiagLastStateSentTextBlock" Text="Last state sent: --" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Margin="0,0,0,12">
                            <Button x:Name="ExportSetupButton" Content="Export Setup" Width="130" Height="34" Margin="0,0,8,8" ToolTip="Export all settings to a JSON file for backup or transfer" Click="ExportSetupButton_Click" />
                            <Button x:Name="ImportSetupButton" Content="Import Setup" Width="130" Height="34" Margin="0,0,8,8" ToolTip="Import settings from a previously exported JSON file" Click="ImportSetupButton_Click" />
                            <Button x:Name="ClearRememberedControllerButton" Content="Clear Remembered Controller" Width="210" Height="34" Margin="0,0,8,8" ToolTip="Clear the remembered COM port — the next launch will scan all ports" Click="ClearRememberedControllerButton_Click" />
                            <Button x:Name="FactoryResetSetupButton" Content="Factory Reset Setup" Width="170" Height="34" Margin="0,0,8,8" ToolTip="Reset all settings to factory defaults (cannot be undone)" Click="FactoryResetSetupButton_Click" />
                        </WrapPanel>

                        <TextBlock Text="Settings are saved automatically whenever you make a change."
                                   Foreground="{DynamicResource SecondaryForeground}"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap" />

                        <!-- Software Updates -->
                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Software Updates"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Automatically checks GitHub for a newer release on startup."
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <TextBlock x:Name="UpdateCheckerStatusTextBlock"
                                           Text="Never checked"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4" />
                                <TextBlock x:Name="UpdateCheckerLastCheckedTextBlock"
                                           Text="Last checked: —"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           Margin="0,0,0,8" />
                                <Button x:Name="CheckForUpdatesButton"
                                        Content="Check now"
                                        Width="110"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        ToolTip="Manually check GitHub for a newer version of the dashboard"
                                        Click="CheckForUpdatesButton_Click" />
                            </StackPanel>
                        </Border>

                        <Button x:Name="AboutButton"
                                Content="About"
                                Width="80"
                                Height="30"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                ToolTip="About this application"
                                Click="AboutButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Hardware Test">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Hardware Test Mode" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Use this to verify encoder direction, button presses, and display commands before relying on Windows audio control." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Content="Send Display Test" Width="140" Height="30" Margin="0,0,8,8" Click="SendHardwareTestPatternButton_Click" />
                                    <Button Content="Show OLED Numbers" Width="150" Height="30" Margin="0,0,8,8" Click="SendShowOledIdentButton_Click" />
                                    <Button Content="Sleep Display" Width="120" Height="30" Margin="0,0,8,8" Click="SendHardwareSleepButton_Click" />
                                    <Button Content="Wake Display" Width="120" Height="30" Margin="0,0,8,8" Click="SendHardwareWakeButton_Click" />
                                    <Button Content="Reset Counters" Width="130" Height="30" Margin="0,0,8,8" Click="ResetHardwareTestButton_Click" />
                                </WrapPanel>
                                <TextBlock x:Name="HardwareTestStatusTextBlock" Text="No hardware events received yet." TextWrapping="Wrap" FontFamily="Consolas" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Debug">
                <Grid Margin="0,12,0,0" Background="{DynamicResource AppBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ⚠ TEMPORARY — window size helper, remove before release -->
                    <Border Grid.Row="0" BorderThickness="1" CornerRadius="8" Padding="10,8"
                            Margin="0,0,0,12"
                            BorderBrush="{DynamicResource WarningForeground}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ Temp — Window size: "
                                       Foreground="{DynamicResource WarningForeground}"
                                       VerticalAlignment="Center" FontSize="13" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F0} × {1:F0}">
                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="ActualWidth" />
                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="ActualHeight" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text=" px   (default 1300 × 900, min 570 × 320)"
                                       Foreground="{DynamicResource SecondaryForeground}"
                                       VerticalAlignment="Center" FontSize="12" Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Serial / Debug Console" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <WrapPanel>
                                <CheckBox x:Name="ShowHeartbeatDebugCheckBox" Content="Show PING/PONG heartbeat" Margin="0,0,16,8" />
                                <Button Content="Clear" Width="80" Height="30" Margin="0,0,8,8" Click="ClearDebugConsoleButton_Click" />
                                <Button Content="Copy" Width="80" Height="30" Margin="0,0,8,8" Click="CopyDebugConsoleButton_Click" />
                                <Button Content="Save Snapshot" Width="130" Height="30" Margin="0,0,8,8" Click="SaveDebugSnapshotButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <TextBox Grid.Row="2" x:Name="DebugConsoleTextBox" FontFamily="Consolas" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
                </Grid>
            </TabItem>
            <TabItem x:Name="FirstRunWizardTab" Header="First Run" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource AppBackground}">
                    <StackPanel Margin="0,12,0,0">
                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="First-Run Setup Wizard" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Use this page to confirm the controller, choose startup behaviour, and then jump to the Audio page to assign channels." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,12" />
                                <TextBlock x:Name="WizardStatusTextBlock" Text="Wizard status: not checked" Margin="0,0,0,4" FontWeight="SemiBold" />
                                <TextBlock x:Name="WizardControllerStatusTextBlock" Text="Controller: not checked" Margin="0,0,0,4" TextWrapping="Wrap" />
                                <TextBlock x:Name="WizardFirmwareStatusTextBlock" Text="Firmware/protocol: not checked" Margin="0,0,0,4" TextWrapping="Wrap" />
                                <TextBlock x:Name="WizardStartupStatusTextBlock" Text="Startup: not checked" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="1. Detect the controller" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Plug in the PC Volume Controller, then click Detect Controller. The dashboard will verify the ESP32 identity before accepting the COM port." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <Button Content="Detect Controller" Width="150" Height="34" HorizontalAlignment="Left" Click="WizardDetectControllerButton_Click" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="2. Choose daily-use startup behaviour" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardAutoConnectCheckBox" Content="Auto-connect to the controller when the dashboard opens" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardStartWithWindowsCheckBox" Content="Start dashboard when Windows starts" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardMinimizeToTrayCheckBox" Content="Minimize to system tray" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardStartMinimizedCheckBox" Content="Start minimized to tray" Margin="0,0,0,8" />
                                <CheckBox x:Name="WizardScanAllCheckBox" Content="Scan all COM ports if the remembered controller is missing" Margin="0,0,0,8" />
                                <TextBlock Text="Recommended daily-use setup: auto-connect on, start with Windows on, minimize to tray on, start minimized on, scan all COM ports off." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,4,0,10" />
                                <WrapPanel>
                                    <Button Content="Apply Recommended" Width="150" Height="34" Margin="0,0,8,8" Click="WizardApplyRecommendedButton_Click" />
                                    <Button Content="Save Wizard Choices" Width="160" Height="34" Margin="0,0,8,8" Click="WizardSaveSetupButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="3. Choose audio backend" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="WASAPI is the standard Windows audio engine and works with all apps. Choose VoiceMeeter only if you already use VoiceMeeter for audio routing."
                                           TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />

                                <RadioButton x:Name="WizardWasapiRadioButton"
                                             Content="WASAPI — Windows audio sessions (recommended)"
                                             GroupName="WizardAudioBackendGroup"
                                             Margin="0,0,0,6"
                                             IsChecked="True" />
                                <RadioButton x:Name="WizardVoiceMeeterRadioButton"
                                             Content="VoiceMeeter — route through VoiceMeeter strips and buses"
                                             GroupName="WizardAudioBackendGroup"
                                             Margin="0,0,0,10" />

                                <Button Content="Save Backend Choice" Width="170" Height="34" HorizontalAlignment="Left"
                                        Click="WizardSaveSetupButton_Click" />
                            </StackPanel>
                        </Border>

                        <Border BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="4. Assign channels" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Open the Audio page to assign each encoder to Master volume, an app, or leave it unassigned." TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,0,10" />
                                <WrapPanel>
                                    <Button Content="Open Audio Page" Width="140" Height="34" Margin="0,0,8,8" Click="WizardOpenAudioPageButton_Click" />
                                    <Button Content="Mark Wizard Complete" Width="170" Height="34" Margin="0,0,8,8" Click="WizardCompleteButton_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <Border Grid.Row="5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Margin="0,12,0,0">
            <TextBlock x:Name="LogTextBlock"
                       Text="Ready."
                       TextWrapping="Wrap" />
        </Border>
        </Grid>
    </DockPanel>
</Window>