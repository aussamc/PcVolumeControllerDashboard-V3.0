<Window x:Class="PcVolumeControllerDashboard.HotkeyPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Hotkey"
        Width="360"
        Height="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="ActionNameTextBlock"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <Border Grid.Row="1"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,12">
            <TextBlock x:Name="PressedComboTextBlock"
                       Text="Press a key combination..."
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#888888"/>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Hold Ctrl, Alt, Shift, and/or Win, then press a key. Press Escape to cancel."
                   Foreground="#888888"
                   TextWrapping="Wrap"
                   FontSize="11"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ClearButton"
                    Content="Clear"
                    Width="70"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="ClearButton_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="70"
                    Height="28"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="Cancel"
                    Width="70"
                    Height="28"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
