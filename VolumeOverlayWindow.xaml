<Window x:Class="PcVolumeControllerDashboard.VolumeOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Width="280"
        SizeToContent="Height"
        ResizeMode="NoResize">

    <Window.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" Y="0"/>
    </Window.RenderTransform>

    <Border x:Name="ContentBorder"
            CornerRadius="12"
            Padding="16,12"
            Background="#CC000000">
        <StackPanel>

            <!-- Channel name — always visible -->
            <TextBlock x:Name="ChannelNameText"
                       Text="Master"
                       FontSize="12"
                       Foreground="#BBFFFFFF"
                       Margin="0,0,0,6"/>

            <!-- Volume row — progress bar + percentage (shown for volume changes) -->
            <Grid x:Name="VolumeRow" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="VolumeProgressBar"
                             Grid.Column="0"
                             Minimum="0" Maximum="100"
                             Value="75"
                             Height="6"
                             Background="#44FFFFFF"
                             Foreground="#FFFFFFFF"
                             BorderThickness="0"
                             VerticalAlignment="Center"/>
                <TextBlock x:Name="VolumePercentText"
                           Grid.Column="1"
                           Text="75%"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFFFF"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Mute row — speaker icon + status text (shown when mute is toggled) -->
            <Grid x:Name="MuteRow" Visibility="Collapsed" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Vector speaker icons (24×24 canvas scaled to 40×40 display) -->
                <Viewbox Grid.Column="0"
                         Width="44" Height="44"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">

                        <!-- Speaker unmuted: cone body + two sound wave arcs -->
                        <Path x:Name="UnmutedSpeakerPath"
                              Data="M 3,7 L 3,17 L 8,17 L 13,22 L 13,2 L 8,7 Z
                                    M 16,9.5 Q 19,12 16,14.5
                                    M 18.5,6.5 Q 23.5,12 18.5,17.5"
                              Fill="Transparent"
                              Stroke="White"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>

                        <!-- Speaker muted: cone body + X cross through the wave area -->
                        <Path x:Name="MutedSpeakerPath"
                              Data="M 3,7 L 3,17 L 8,17 L 13,22 L 13,2 L 8,7 Z
                                    M 16,8.5 L 23,15.5
                                    M 23,8.5 L 16,15.5"
                              Fill="Transparent"
                              Stroke="White"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Visibility="Collapsed"/>

                    </Canvas>
                </Viewbox>

                <!-- Muted / Unmuted label -->
                <TextBlock x:Name="MuteStatusText"
                           Grid.Column="1"
                           Text="Muted"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
