<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PcVolumeControllerDashboard.App.AudioBackendWizardPage">
    <StackPanel x:Name="Root" Spacing="6">
        <!-- Radio content and the two notes are set in code-behind: they name the
             concrete backend for the running OS (see Audio/AudioBackendLabels). -->
        <TextBlock x:Name="ChoiceDescriptionText" Classes="muted" />
        <RadioButton x:Name="WasapiRadio"
                     GroupName="AudioBackend"
                     Checked="AudioBackendRadio_Changed"
                     Unchecked="AudioBackendRadio_Changed" />
        <RadioButton x:Name="VoiceMeeterRadio"
                     GroupName="AudioBackend"
                     Checked="AudioBackendRadio_Changed"
                     Unchecked="AudioBackendRadio_Changed" />
        <TextBlock x:Name="VoiceMeeterNoteText" Classes="muted" />
        <TextBlock x:Name="StatusText" Classes="muted" />
    </StackPanel>
</UserControl>
