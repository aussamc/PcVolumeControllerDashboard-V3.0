<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PcVolumeControllerDashboard.App.AudioBackendWizardPage">
    <StackPanel x:Name="Root" Spacing="6">
        <TextBlock Classes="muted"
                   Text="Choose how volume is routed. WASAPI works for most setups; pick VoiceMeeter only if you use it." />
        <RadioButton x:Name="WasapiRadio"
                     GroupName="AudioBackend"
                     Content="Windows audio (WASAPI)"
                     Checked="AudioBackendRadio_Changed"
                     Unchecked="AudioBackendRadio_Changed" />
        <RadioButton x:Name="VoiceMeeterRadio"
                     GroupName="AudioBackend"
                     Content="VoiceMeeter"
                     Checked="AudioBackendRadio_Changed"
                     Unchecked="AudioBackendRadio_Changed" />
        <TextBlock Classes="muted" Text="VoiceMeeter is Windows-only." />
        <TextBlock x:Name="StatusText" Classes="muted" />
    </StackPanel>
</UserControl>
