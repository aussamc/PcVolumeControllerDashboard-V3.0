<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PcVolumeControllerDashboard.App"
        mc:Ignorable="d"
        x:Class="PcVolumeControllerDashboard.App.MainWindow"
        Title="PC Volume Controller Dashboard"
        Icon="/Assets/app-icon.ico"
        Width="980" Height="720"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Card container for each settings group. -->
        <Style Selector="Border.card">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.h3">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <!-- Collapsible section for the Setup tab (v3.17 declutter). -->
        <Style Selector="Expander.section">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Window.Styles>

    <TabControl x:Name="MainTabs">
        <TabItem Header="Audio">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">

                    <!-- ── Auto-update banner (v3.19) ───────────────────────── -->
                    <Border x:Name="UpdateBanner" Classes="card" IsVisible="False"
                            BorderBrush="{DynamicResource SystemAccentColor}" BorderThickness="1"
                            Margin="0,0,0,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Update available" Classes="h2" />
                            <TextBlock x:Name="UpdateBannerText" TextWrapping="Wrap"
                                       Text="A new version is available." />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="UpdateBannerInstallButton" Content="Download &amp; install"
                                        IsVisible="False" Classes="accent"
                                        Click="UpdateBannerInstall_Click"
                                        ToolTip.Tip="Download the update for your platform and launch the installer" />
                                <Button x:Name="UpdateBannerViewButton" Content="View release"
                                        Click="UpdateBannerView_Click"
                                        ToolTip.Tip="Open the release page in your browser" />
                                <Button x:Name="UpdateBannerSkipButton" Content="Skip this version"
                                        Click="UpdateBannerSkip_Click"
                                        ToolTip.Tip="Stop reminding me about this version until a newer one is released" />
                                <Button x:Name="UpdateBannerDismissButton" Content="Remind me later"
                                        Click="UpdateBannerDismiss_Click"
                                        ToolTip.Tip="Hide this until the next check" />
                            </StackPanel>
                            <TextBlock x:Name="UpdateBannerProgress" Classes="muted" IsVisible="False"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- ── Connection status ────────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="h2" Text="Controller" />
                            <TextBlock x:Name="ConnectionStatusText" Text="Disconnected" Margin="0,0,0,8" />
                            <TextBlock x:Name="SafeModeBanner" IsVisible="False" Foreground="OrangeRed"
                                       TextWrapping="Wrap" Margin="0,0,0,8"
                                       Text="Safe mode (--safe): auto-connect and audio-control writes are disabled. Use Reconnect or the port picker below to connect manually." />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ReconnectButton" Content="Reconnect" Click="ReconnectButton_Click"
                                        ToolTip.Tip="Scan the COM ports and connect to the controller" />
                                <Button x:Name="DisconnectButton" Content="Disconnect" Click="DisconnectButton_Click"
                                        ToolTip.Tip="Close the connection and stop auto-reconnecting until you reconnect" />
                            </StackPanel>

                            <!-- Manual per-port picker (N2): connect to a specific port,
                                 bypassing auto-detect (useful with a second serial device). -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <TextBlock Text="Port:" VerticalAlignment="Center" />
                                <ComboBox x:Name="PortCombo" Width="160" MinWidth="120"
                                          DropDownOpened="PortCombo_DropDownOpened"
                                          ToolTip.Tip="Pick a specific serial port to connect to, bypassing auto-detect" />
                                <Button x:Name="ConnectPortButton" Content="Connect to port" Click="ConnectToPort_Click"
                                        ToolTip.Tip="Connect to the selected port instead of auto-detecting the controller" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Channel mapping (live) ───────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="h2" Text="Channel Mapping" />
                            <TextBlock Classes="muted" Margin="0,0,0,8"
                                       Text="Live channel state. Turning an encoder or pressing a knob updates the assigned target here." />

                            <DataGrid x:Name="ChannelGrid"
                                      x:DataType="local:ChannelRow"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      Height="232"
                                      GridLinesVisibility="Horizontal"
                                      SelectionChanged="ChannelGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ch" Binding="{Binding Channel}" Width="50" />
                                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="2*" MinWidth="120" />
                                    <DataGridTextColumn Header="Assigned Target" Binding="{Binding AssignedLabel}" Width="2*" MinWidth="120" />
                                    <DataGridTextColumn Header="Volume" Binding="{Binding VolumeDisplay}" Width="Auto" MinWidth="80" />
                                    <DataGridTextColumn Header="Mute" Binding="{Binding MuteDisplay}" Width="Auto" MinWidth="64" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.5*" MinWidth="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── Target assignment ────────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="h2" Text="Assign Target" />
                            <TextBlock Classes="muted" Margin="0,0,0,8"
                                       Text="Pick a channel row above, choose an available audio target, and assign it." />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="TargetCombo" Width="300" />
                                <Button Content="Assign to selected channel" Margin="8,0,0,0" Click="AssignTarget_Click" />
                                <Button Content="Clear" Margin="8,0,0,0" Click="ClearTarget_Click" />
                                <Button Content="Refresh targets" Margin="8,0,0,0" Click="RefreshTargets_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Per-channel detail ───────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel x:Name="ChannelDetailPanel">
                            <TextBlock Classes="h2" x:Name="DetailHeaderText" Text="Channel Detail" />
                            <TextBlock Classes="muted" Margin="0,0,0,8"
                                       Text="Select a channel row above to edit its name, button actions, sensitivity, volume limits, presets, and OLED mode." />

                            <Grid ColumnDefinitions="170,*" RowDefinitions="Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0" Text="Display name" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="DetailNameBox" Width="260" HorizontalAlignment="Left"
                                         LostFocus="DetailName_Committed" KeyDown="DetailName_KeyDown" />
                            </Grid>

                            <TextBlock Classes="h3" Text="Button actions" Margin="0,8,0,4" />
                            <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Short press" VerticalAlignment="Center" Margin="0,3" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="DetailShortActionCombo" Width="260" HorizontalAlignment="Left" Margin="0,3"
                                          SelectionChanged="DetailShortAction_Changed" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Long press" VerticalAlignment="Center" Margin="0,3" />
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DetailLongActionCombo" Width="260" HorizontalAlignment="Left" Margin="0,3"
                                          SelectionChanged="DetailLongAction_Changed" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Double press" VerticalAlignment="Center" Margin="0,3" />
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DetailDoubleActionCombo" Width="260" HorizontalAlignment="Left" Margin="0,3"
                                          SelectionChanged="DetailDoubleAction_Changed" />
                            </Grid>

                            <TextBlock Classes="h3" Text="Encoder sensitivity" Margin="0,12,0,4" />
                            <CheckBox x:Name="DetailSensOverrideCheck" Content="Override global sensitivity for this channel"
                                      IsCheckedChanged="DetailSensOverride_Changed" />
                            <StackPanel Orientation="Horizontal" x:Name="DetailSensRow" Spacing="8">
                                <Slider x:Name="DetailSensSlider" Width="360" Minimum="0" Maximum="500" TickFrequency="10" IsSnapToTickEnabled="True" />
                                <TextBlock x:Name="DetailSensValueText" VerticalAlignment="Center" Text="50%" />
                            </StackPanel>

                            <TextBlock Classes="h3" Text="Volume limits" Margin="0,12,0,4" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Min %" VerticalAlignment="Center" />
                                <NumericUpDown x:Name="DetailMinVol" Width="120" Minimum="0" Maximum="100" Increment="1"
                                               FormatString="0" ValueChanged="DetailVolumeLimit_Changed" />
                                <TextBlock Text="Max %" VerticalAlignment="Center" Margin="12,0,0,0" />
                                <NumericUpDown x:Name="DetailMaxVol" Width="120" Minimum="0" Maximum="100" Increment="1"
                                               FormatString="0" ValueChanged="DetailVolumeLimit_Changed" />
                            </StackPanel>

                            <TextBlock Classes="h3" Text="Volume presets" Margin="0,12,0,4" />
                            <TextBlock Classes="muted" Margin="0,0,0,6"
                                       Text="Assign a button action to Apply Preset 1/2/3 to jump the channel to these volumes." />
                            <Grid ColumnDefinitions="80,*,160" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Preset 1" VerticalAlignment="Center" Margin="0,3" />
                                <TextBox    Grid.Row="0" Grid.Column="1" x:Name="DetailPreset1Name" Watermark="Name (optional)" Margin="0,3"
                                            LostFocus="DetailPreset_Committed" KeyDown="DetailName_KeyDown" />
                                <NumericUpDown Grid.Row="0" Grid.Column="2" x:Name="DetailPreset1Vol" Minimum="0" Maximum="100" Increment="1" Margin="6,3"
                                               FormatString="0" ValueChanged="DetailPreset_Changed" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Preset 2" VerticalAlignment="Center" Margin="0,3" />
                                <TextBox    Grid.Row="1" Grid.Column="1" x:Name="DetailPreset2Name" Watermark="Name (optional)" Margin="0,3"
                                            LostFocus="DetailPreset_Committed" KeyDown="DetailName_KeyDown" />
                                <NumericUpDown Grid.Row="1" Grid.Column="2" x:Name="DetailPreset2Vol" Minimum="0" Maximum="100" Increment="1" Margin="6,3"
                                               FormatString="0" ValueChanged="DetailPreset_Changed" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Preset 3" VerticalAlignment="Center" Margin="0,3" />
                                <TextBox    Grid.Row="2" Grid.Column="1" x:Name="DetailPreset3Name" Watermark="Name (optional)" Margin="0,3"
                                            LostFocus="DetailPreset_Committed" KeyDown="DetailName_KeyDown" />
                                <NumericUpDown Grid.Row="2" Grid.Column="2" x:Name="DetailPreset3Vol" Minimum="0" Maximum="100" Increment="1" Margin="6,3"
                                               FormatString="0" ValueChanged="DetailPreset_Changed" />
                            </Grid>

                            <TextBlock Classes="h3" Text="OLED display mode" Margin="0,12,0,4" />
                            <ComboBox x:Name="DetailOledModeCombo" Width="260" HorizontalAlignment="Left"
                                      SelectionChanged="DetailOledMode_Changed" />

                            <TextBlock Classes="h3" Text="Link group" Margin="0,12,0,4" />
                            <TextBlock Classes="muted" Margin="0,0,0,4"
                                       Text="Channels sharing the same link group name move together when you turn any one of them (ganged volume). Leave blank for none." />
                            <TextBox x:Name="DetailLinkGroupBox" Width="260" HorizontalAlignment="Left" Watermark="e.g. headset"
                                     LostFocus="DetailLinkGroup_Committed" KeyDown="DetailLinkGroup_KeyDown" />

                            <TextBlock Classes="h3" Text="Multi-app pool" Margin="0,12,0,4" />
                            <TextBlock Classes="muted" Margin="0,0,0,4"
                                       Text="Optional. Add several targets and the channel controls whichever one is currently making sound (first live match wins) — handy for a 'browser' or 'music' channel that follows whatever's playing. A non-empty pool overrides the single assigned target above." />
                            <ListBox x:Name="DetailPoolList" Height="92" Width="320" HorizontalAlignment="Left" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                <ComboBox x:Name="DetailPoolCombo" Width="220" />
                                <Button Content="Add" Click="DetailPoolAdd_Click" />
                                <Button Content="Remove" Click="DetailPoolRemove_Click" />
                                <Button Content="Clear" Click="DetailPoolClear_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Setup">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">

                    <!-- ── App info ─────────────────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="h1" Text="PC Volume Controller" />
                            <TextBlock x:Name="DashboardVersionText" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock x:Name="ExpectedProtocolText" Margin="0,0,0,4" />
                            <TextBlock x:Name="SettingsPathText" Classes="muted" Margin="0,0,0,8" />
                            <WrapPanel>
                                <Button x:Name="AboutButton" Content="About" Margin="0,0,8,0" Click="AboutButton_Click" />
                                <Button x:Name="OpenLogFolderButton" Content="Open log folder" Margin="0,0,8,0" Click="OpenLogFolderButton_Click" />
                                <Button x:Name="CopySettingsPathButton" Content="Copy settings path" Margin="0,0,8,0" Click="CopySettingsPathButton_Click" />
                                <Button x:Name="ExportDiagnosticsButton" Content="Export diagnostics" Click="ExportDiagnosticsButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="DiagnosticsStatusText" Classes="muted" Margin="0,8,0,0" IsVisible="False" />

                            <Separator Margin="0,10,0,8" />
                            <TextBlock Text="Software Updates" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="CheckUpdatesButton" Content="Check for updates"
                                        Click="CheckUpdatesButton_Click"
                                        ToolTip.Tip="Query GitHub for a newer release of the dashboard" />
                                <Button x:Name="UpdateInstallButton" Content="Download &amp; install" IsVisible="False"
                                        Classes="accent"
                                        Click="UpdateInstall_Click"
                                        ToolTip.Tip="Download the update for your platform and launch the installer" />
                                <Button x:Name="ViewReleaseButton" Content="View release" IsVisible="False"
                                        Click="ViewReleaseButton_Click"
                                        ToolTip.Tip="Open the release page in your browser" />
                            </StackPanel>
                            <TextBlock x:Name="UpdateStatusText" Classes="muted" Margin="0,8,0,0" IsVisible="False" />
                            <TextBlock x:Name="UpdateInstallProgress" Classes="muted" Margin="0,6,0,0" IsVisible="False" />
                        </StackPanel>
                    </Border>

                    <!-- ── Application Setup ────────────────────────────────── -->
                    <Expander Classes="section" IsExpanded="True">
                        <Expander.Header><TextBlock Classes="h2" Text="Application Setup" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <CheckBox x:Name="AutoConnectCheckBox" Content="Auto-connect on launch"
                                      ToolTip.Tip="Automatically connect to the controller when the dashboard opens"
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />
                            <CheckBox x:Name="ScanAllComPortsCheckBox" Content="Scan all COM ports if remembered controller is missing"
                                      ToolTip.Tip="Scan all COM ports for the controller if the remembered port is not found. Leave off for daily use."
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />
                            <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Minimize to system tray"
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />
                            <CheckBox x:Name="StartMinimizedToTrayCheckBox" Content="Start minimized to tray"
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />
                            <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start program at login"
                                      ToolTip.Tip="Windows only for now; Linux/macOS autostart wired in a later PR"
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />
                            <CheckBox x:Name="TrayNotificationsCheckBox" Content="Show tray notifications"
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />
                            <CheckBox x:Name="AdvancedDebugFeaturesCheckBox" Content="Advanced debug features (show Debug tab)"
                                      ToolTip.Tip="Shows the Debug tab: live serial console, hardware self-test, and diagnostics readout. Off by default; launch with --debug to force it on for one session."
                                      IsCheckedChanged="AppSetupCheckBox_Changed" />

                            <Separator Margin="0,8,0,8" />
                            <TextBlock Text="Controller Pairing" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock x:Name="PairedControllerText" Classes="muted" Text="Paired controller: (none)" Margin="0,0,0,8" />
                            <Button x:Name="ForgetControllerButton" Content="Forget controller"
                                    HorizontalAlignment="Left"
                                    ToolTip.Tip="Clear the paired controller chip ID so the next connection auto-pairs with any controller"
                                    Click="ForgetControllerButton_Click" />
                        </StackPanel>
                    </Expander>

                    <!-- ── Global Hotkeys ───────────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Global Hotkeys" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <TextBlock Classes="muted" Margin="0,0,0,8"
                                       Text="System-wide shortcuts that work even when the dashboard is in the background. Click Set, then press a key combination." />

                            <Grid ColumnDefinitions="190,*,Auto,Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0" Text="Master volume up" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="HotkeyMasterUpText" Text="(unassigned)" VerticalAlignment="Center" Opacity="0.8" />
                                <Button Grid.Column="2" Content="Set…" Margin="0,0,6,0" Click="HotkeyMasterUpSet_Click" />
                                <Button Grid.Column="3" Content="Clear" Click="HotkeyMasterUpClear_Click" />
                            </Grid>

                            <Grid ColumnDefinitions="190,*,Auto,Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0" Text="Master volume down" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="HotkeyMasterDownText" Text="(unassigned)" VerticalAlignment="Center" Opacity="0.8" />
                                <Button Grid.Column="2" Content="Set…" Margin="0,0,6,0" Click="HotkeyMasterDownSet_Click" />
                                <Button Grid.Column="3" Content="Clear" Click="HotkeyMasterDownClear_Click" />
                            </Grid>

                            <Grid ColumnDefinitions="190,*,Auto,Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0" Text="Toggle master mute" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="HotkeyMasterMuteText" Text="(unassigned)" VerticalAlignment="Center" Opacity="0.8" />
                                <Button Grid.Column="2" Content="Set…" Margin="0,0,6,0" Click="HotkeyMasterMuteSet_Click" />
                                <Button Grid.Column="3" Content="Clear" Click="HotkeyMasterMuteClear_Click" />
                            </Grid>

                            <Grid ColumnDefinitions="190,*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="Show dashboard" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="HotkeyShowDashboardText" Text="(unassigned)" VerticalAlignment="Center" Opacity="0.8" />
                                <Button Grid.Column="2" Content="Set…" Margin="0,0,6,0" Click="HotkeyShowDashboardSet_Click" />
                                <Button Grid.Column="3" Content="Clear" Click="HotkeyShowDashboardClear_Click" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- ── Encoder Sensitivity ──────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Encoder Sensitivity" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <TextBlock Classes="muted" Margin="0,0,0,10"
                                       Text="Controls how much the volume changes for each encoder click. 50% is the default; higher values allow much faster changes." />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sensitivity:" VerticalAlignment="Center" Width="110" />
                                <Slider x:Name="EncoderSensitivitySlider" Minimum="0" Maximum="500" TickFrequency="10" IsSnapToTickEnabled="True" Width="360" VerticalAlignment="Center" />
                                <TextBlock x:Name="EncoderSensitivityValueText" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" Text="50%" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ── Encoder Feel ─────────────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Encoder Feel" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <TextBlock Classes="muted" Margin="0,0,0,12"
                                       Text="Volume acceleration scales the step when you turn the encoder quickly. Volume smoothing eases volume to its target over a short time rather than jumping instantly." />

                            <CheckBox x:Name="AccelerationEnabledCheckBox" Content="Enable volume acceleration"
                                      IsCheckedChanged="EncoderFeelCheckBox_Changed" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Acceleration preset:" VerticalAlignment="Center" Width="140" />
                                <ComboBox x:Name="AccelerationPresetComboBox" Width="180" SelectionChanged="AccelerationPresetComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Medium" />
                                    <ComboBoxItem Content="Aggressive" />
                                    <ComboBoxItem Content="Custom" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="AccelCustomPanel" IsVisible="False" Margin="0,0,0,8">
                                <TextBlock Text="Custom acceleration tuning" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Speed threshold:" VerticalAlignment="Center" Width="150" />
                                    <Slider x:Name="AccelThresholdSlider" Minimum="20" Maximum="250" TickFrequency="10" IsSnapToTickEnabled="True" Width="220" />
                                    <TextBlock x:Name="AccelThresholdLabel" VerticalAlignment="Center" Margin="8,0,0,0" Text="150 ms" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Max multiplier:" VerticalAlignment="Center" Width="150" />
                                    <Slider x:Name="AccelMaxMultiplierSlider" Minimum="1.5" Maximum="8.0" TickFrequency="0.5" IsSnapToTickEnabled="True" Width="220" />
                                    <TextBlock x:Name="AccelMaxMultiplierLabel" VerticalAlignment="Center" Margin="8,0,0,0" Text="8.0x" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Curve shape:" VerticalAlignment="Center" Width="150" />
                                    <Slider x:Name="AccelCurveSlider" Minimum="0.3" Maximum="2.5" TickFrequency="0.1" IsSnapToTickEnabled="True" Width="220" />
                                    <TextBlock x:Name="AccelCurveLabel" VerticalAlignment="Center" Margin="8,0,0,0" Text="Early" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox x:Name="VolumeSmoothingEnabledCheckBox" Content="Enable volume smoothing"
                                      IsCheckedChanged="EncoderFeelCheckBox_Changed" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Smoothing speed:" VerticalAlignment="Center" Width="140" />
                                <ComboBox x:Name="VolumeSmoothingSpeedComboBox" Width="180" SelectionChanged="VolumeSmoothingSpeedComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Fast (~60 ms)" />
                                    <ComboBoxItem Content="Normal (~100 ms)" />
                                    <ComboBoxItem Content="Slow (~150 ms)" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ── Style Settings ───────────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Style Settings" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <RadioButton x:Name="ThemeFollowSystemRadioButton" GroupName="ThemeMode" Content="Follow System" Margin="0,0,0,8" IsCheckedChanged="ThemeRadioButton_Changed" />
                            <RadioButton x:Name="ThemeLightRadioButton" GroupName="ThemeMode" Content="Light Mode" Margin="0,0,0,8" IsCheckedChanged="ThemeRadioButton_Changed" />
                            <RadioButton x:Name="ThemeDarkRadioButton" GroupName="ThemeMode" Content="Dark Mode" Margin="0,0,0,8" IsCheckedChanged="ThemeRadioButton_Changed" />
                        </StackPanel>
                    </Expander>

                    <!-- ── Volume Overlay ───────────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Volume Overlay" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <TextBlock Classes="muted" Margin="0,0,0,10"
                                       Text="Shows the channel name and volume level on-screen when you turn an encoder knob." />
                            <CheckBox x:Name="OverlayEnabledCheckBox" Content="Show volume overlay when encoder turns"
                                      IsCheckedChanged="OverlayCheckBox_Changed" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Screen position:" VerticalAlignment="Center" Width="130" />
                                <ComboBox x:Name="OverlayPositionComboBox" Width="200" SelectionChanged="OverlayPositionComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Top Left" Tag="TopLeft" />
                                    <ComboBoxItem Content="Top Center" Tag="TopCenter" />
                                    <ComboBoxItem Content="Top Right" Tag="TopRight" />
                                    <ComboBoxItem Content="Bottom Left" Tag="BottomLeft" />
                                    <ComboBoxItem Content="Bottom Center" Tag="BottomCenter" />
                                    <ComboBoxItem Content="Bottom Right" Tag="BottomRight" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Dismiss after:" VerticalAlignment="Center" Width="130" />
                                <Slider x:Name="OverlayTimeoutSlider" Minimum="1" Maximum="8" TickFrequency="0.5" IsSnapToTickEnabled="True" Width="200" />
                                <TextBlock x:Name="OverlayTimeoutValueText" VerticalAlignment="Center" Margin="8,0,0,0" Text="2.5 s" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Transparency:" VerticalAlignment="Center" Width="130" />
                                <Slider x:Name="OverlayOpacitySlider" Minimum="30" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Width="200" />
                                <TextBlock x:Name="OverlayOpacityValueText" VerticalAlignment="Center" Margin="8,0,0,0" Text="100%" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Size:" VerticalAlignment="Center" Width="130" />
                                <Slider x:Name="OverlayScaleSlider" Minimum="75" Maximum="150" TickFrequency="5" IsSnapToTickEnabled="True" Width="200" />
                                <TextBlock x:Name="OverlayScaleValueText" VerticalAlignment="Center" Margin="8,0,0,0" Text="100%" />
                            </StackPanel>
                            <CheckBox x:Name="OverlayAllScreensCheckBox" Content="Show on all screens"
                                      IsCheckedChanged="OverlayAllScreensCheckBox_Changed" Margin="0,0,0,8" />
                            <Button x:Name="OverlayPreviewButton" Content="Preview" Click="OverlayPreviewButton_Click"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Expander>

                    <!-- ── Maintenance ──────────────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Maintenance" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <WrapPanel>
                                <Button x:Name="ExportSettingsButton" Content="Export settings…" Margin="0,0,8,0"
                                        ToolTip.Tip="Save a copy of your current settings to a file"
                                        Click="ExportSettingsButton_Click" />
                                <Button x:Name="ImportSettingsButton" Content="Import settings…" Margin="0,0,8,0"
                                        ToolTip.Tip="Replace your current settings with a previously exported file"
                                        Click="ImportSettingsButton_Click" />
                                <Button x:Name="FactoryResetButton" Content="Factory Reset Setup"
                                        ToolTip.Tip="Reset all settings to factory defaults (cannot be undone)"
                                        Click="FactoryResetButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="SettingsIoStatusText" Classes="muted" Margin="0,8,0,0" IsVisible="False" />
                            <TextBlock Classes="muted" FontStyle="Italic" Margin="0,8,0,0"
                                       Text="Settings are saved automatically whenever you make a change." />

                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="Setup Wizard" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Classes="muted" Margin="0,0,0,8"
                                       Text="Re-run the guided setup to reconnect, check the displays, and re-map your channels." />
                            <Button x:Name="RunSetupWizardButton" Content="Run setup wizard again"
                                    HorizontalAlignment="Left"
                                    ToolTip.Tip="Open the first-run setup wizard again"
                                    Click="RunSetupWizardButton_Click" />
                        </StackPanel>
                    </Expander>

                    <!-- ── Audio backend ────────────────────────────────────── -->
                    <Expander Classes="section">
                        <Expander.Header><TextBlock Classes="h2" Text="Audio Backend" Margin="0" /></Expander.Header>
                        <StackPanel>
                            <TextBlock Classes="muted" Margin="0,0,0,8"
                                       Text="WASAPI controls Windows app/session volumes directly. VoiceMeeter routes through the VoiceMeeter Remote API (Windows only; requires VoiceMeeter installed and running)." />
                            <RadioButton x:Name="WasapiRadioButton" GroupName="AudioBackend" Content="WASAPI (Windows audio sessions)"
                                         IsCheckedChanged="AudioBackendRadioButton_Changed" />
                            <RadioButton x:Name="VoiceMeeterRadioButton" GroupName="AudioBackend" Content="VoiceMeeter"
                                         IsCheckedChanged="AudioBackendRadioButton_Changed" />
                            <TextBlock x:Name="AudioBackendStatusText" Classes="muted" Margin="0,4,0,0" />
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="OLED Setup">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">

                    <!-- ── OLED Display Settings ────────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="h2" Text="OLED Display Settings" />
                            <TextBlock Classes="muted" Margin="0,0,0,10"
                                       Text="These settings drive the controller preview below and are sent to the ESP32 when it's connected." />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Display mode:" VerticalAlignment="Center" Width="160" />
                                <ComboBox x:Name="DisplayModeComboBox" Width="260" SelectionChanged="DisplayModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="App name + volume" />
                                    <ComboBoxItem Content="Large volume number" />
                                    <ComboBoxItem Content="Mute status" />
                                    <ComboBoxItem Content="App/device name" />
                                    <ComboBoxItem Content="Simple bar/percentage view" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Brightness:" VerticalAlignment="Center" Width="210" />
                                <Slider x:Name="OledBrightnessSlider" Minimum="0" Maximum="100" Width="210" VerticalAlignment="Center" />
                                <TextBlock x:Name="OledBrightnessValueText" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" Text="100%" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Disconnected sleep timeout:" VerticalAlignment="Center" Width="210" />
                                <Slider x:Name="OledSleepTimeoutSlider" Minimum="1" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" Width="210" VerticalAlignment="Center" />
                                <TextBlock x:Name="OledSleepTimeoutValueText" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" Text="2 minute(s)" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Connected idle action:" VerticalAlignment="Center" Width="160" />
                                <ComboBox x:Name="OledConnectedIdleActionComboBox" Width="260" SelectionChanged="OledConnectedIdleActionComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Turn off display" />
                                    <ComboBoxItem Content="Dim brightness to 10%" />
                                    <ComboBoxItem Content="Dim brightness to 20%" />
                                    <ComboBoxItem Content="Dim brightness to 30%" />
                                    <ComboBoxItem Content="Dim brightness to 40%" />
                                    <ComboBoxItem Content="Dim brightness to 50%" />
                                    <ComboBoxItem Content="Dim brightness to 60%" />
                                    <ComboBoxItem Content="Dim brightness to 70%" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Connected idle timeout:" VerticalAlignment="Center" Width="210" />
                                <Slider x:Name="OledConnectedIdleTimeoutSlider" Minimum="1" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" Width="210" VerticalAlignment="Center" />
                                <TextBlock x:Name="OledConnectedIdleTimeoutValueText" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" Text="10 minute(s)" />
                            </StackPanel>

                            <CheckBox x:Name="OledAntiBurnInCheckBox" Content="Enable anti-burn-in pixel shifting"
                                      ToolTip.Tip="Shifts pixels slightly over time to prevent OLED burn-in"
                                      IsCheckedChanged="OledAntiBurnInCheckBox_Changed" />
                        </StackPanel>
                    </Border>

                    <!-- ── Whole Controller Preview ─────────────────────────── -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="h1" Text="Whole Controller Preview" />
                            <TextBlock x:Name="OledPreviewModeText" FontWeight="SemiBold" Margin="0,0,0,4" Text="Preview mode: App name + volume" />
                            <TextBlock Classes="muted" Margin="0,0,0,12"
                                       Text="Each OLED renders the same 128x64 canvas the firmware draws, scaled up here. Previews use each channel's saved name with sample volumes (live device data ports with the serial layer)." />

                            <UniformGrid Columns="6" Rows="1">
                                <StackPanel Margin="6,0">
                                    <TextBlock x:Name="OledPreview1Title" Text="OLED 1" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                        <Image x:Name="OledPreview1Image" Width="160" Height="80" Stretch="Fill" RenderOptions.BitmapInterpolationMode="None" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="6,0">
                                    <TextBlock x:Name="OledPreview2Title" Text="OLED 2" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                        <Image x:Name="OledPreview2Image" Width="160" Height="80" Stretch="Fill" RenderOptions.BitmapInterpolationMode="None" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="6,0">
                                    <TextBlock x:Name="OledPreview3Title" Text="OLED 3" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                        <Image x:Name="OledPreview3Image" Width="160" Height="80" Stretch="Fill" RenderOptions.BitmapInterpolationMode="None" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="6,0">
                                    <TextBlock x:Name="OledPreview4Title" Text="OLED 4" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                        <Image x:Name="OledPreview4Image" Width="160" Height="80" Stretch="Fill" RenderOptions.BitmapInterpolationMode="None" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="6,0">
                                    <TextBlock x:Name="OledPreview5Title" Text="OLED 5" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                        <Image x:Name="OledPreview5Image" Width="160" Height="80" Stretch="Fill" RenderOptions.BitmapInterpolationMode="None" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="6,0">
                                    <TextBlock x:Name="OledPreview6Title" Text="OLED 6" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                    <Border BorderBrush="#444444" BorderThickness="1" HorizontalAlignment="Center">
                                        <Image x:Name="OledPreview6Image" Width="160" Height="80" Stretch="Fill" RenderOptions.BitmapInterpolationMode="None" />
                                    </Border>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Debug" x:Name="DebugTab">
            <DockPanel Margin="12">

                <!-- ── Diagnostics (Q6) + hardware self-test (Q4) ───────────── -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,12,*" Margin="0,0,0,10">

                    <!-- Q6 — always-on diagnostics readout. The colour-coded
                         protocol/channel-mismatch WARNING lives on the Audio tab's
                         connection status line (v3.12); this is the plain detail. -->
                    <Border Grid.Column="0" Classes="card" Margin="0">
                        <StackPanel>
                            <TextBlock Classes="h3" Text="Diagnostics" Margin="0,0,0,6" />
                            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="muted" Text="Connection" />
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DiagConnectionText" Text="—" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="muted" Text="COM port" />
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DiagPortText" Text="—" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="muted" Text="Last heartbeat" />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DiagHeartbeatText" Text="—" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="muted" Text="Protocol" />
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DiagProtocolText" Text="—" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Classes="muted" Text="Channels" />
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DiagChannelsText" Text="—" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Classes="muted" Text="Last ESP32 msg" />
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DiagLastRxText" Text="—" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="6" Grid.Column="0" Classes="muted" Text="Last state sent" />
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DiagLastStateText" Text="—" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Q4 — hardware self-test: confirm every encoder + button. -->
                    <Border Grid.Column="2" Classes="card" Margin="0">
                        <StackPanel>
                            <TextBlock Classes="h3" Text="Hardware self-test" Margin="0,0,0,4" />
                            <TextBlock Classes="muted" Margin="0,0,0,6"
                                       Text="Connect the controller, then turn each encoder and press each button — every channel should tally below." />
                            <SelectableTextBlock x:Name="SelfTestText" FontFamily="Cascadia Mono,Consolas,monospace"
                                                 FontSize="12" Text="Channel 1: encoder count 0, button seen no" />
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                <Button Content="Reset" Click="SelfTestReset_Click" />
                                <Button Content="Sleep test" Click="SelfTestSleep_Click"
                                        ToolTip.Tip="Send SLEEP so the OLEDs blank (verifies sleep)" />
                                <Button Content="Wake test" Click="SelfTestWake_Click"
                                        ToolTip.Tip="Send WAKE and repaint the OLEDs (verifies wake)" />
                            </StackPanel>
                            <TextBlock x:Name="SelfTestStatusText" Classes="muted" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Serial console header ────────────────────────────────── -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <TextBlock Text="Serial console" Classes="h2" VerticalAlignment="Center" Margin="0" />
                    <CheckBox x:Name="DebugAutoScrollCheck" Content="Auto-scroll" IsChecked="True" Margin="16,0,0,0" VerticalAlignment="Center" />
                    <CheckBox x:Name="DebugPauseCheck" Content="Pause" Margin="0" VerticalAlignment="Center"
                              IsCheckedChanged="DebugPause_Changed" />
                    <Button Content="Clear" Click="DebugClear_Click" />
                </StackPanel>

                <!-- ── Manual send + quick commands + log helpers (bottom) ──── -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="DebugSendBox" Width="320" Watermark="Type a command (e.g. PING) and press Enter"
                                 KeyDown="DebugSend_KeyDown" />
                        <Button Content="Send" Click="DebugSend_Click" />
                        <TextBlock x:Name="DebugSendStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                        <TextBlock Text="Quick:" Classes="muted" VerticalAlignment="Center" />
                        <Button Content="Ping" Tag="PING" Click="DebugQuick_Click" />
                        <Button Content="Show ident" Tag="SHOW_IDENT" Click="DebugQuick_Click" />
                        <Button Content="Scan I2C" Tag="SCAN_I2C" Click="DebugQuick_Click" />
                        <Button Content="Test display" Tag="TEST_DISPLAY" Click="DebugQuick_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                        <TextBlock Text="Logs:" Classes="muted" VerticalAlignment="Center" />
                        <Button Content="Copy console" Click="DebugCopyConsole_Click"
                                ToolTip.Tip="Copy the live serial console text to the clipboard" />
                        <Button Content="Copy log folder path" Click="DebugCopyLogPath_Click"
                                ToolTip.Tip="Copy the logs folder path to the clipboard" />
                        <Button Content="Open current log file" Click="DebugOpenLogFile_Click"
                                ToolTip.Tip="Open this session's log file with the default handler" />
                        <TextBlock x:Name="DebugLogHelperStatus" Classes="muted" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox x:Name="AdvancedDebugLoggingCheckBox" Content="Advanced debug logging"
                              Margin="0,8,0,0"
                              ToolTip.Tip="Persist the full raw serial traffic (every TX/RX line, as shown in the live console below) plus per-encoder volume changes and button-press actions to this session's log file. Off by default — verbose; turn on when diagnosing a controller issue, then share the log."
                              IsCheckedChanged="AppSetupCheckBox_Changed" />
                </StackPanel>

                <!-- ── Live traffic ─────────────────────────────────────────── -->
                <Border BorderThickness="1" CornerRadius="4"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                    <ScrollViewer x:Name="DebugScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <SelectableTextBlock x:Name="DebugConsoleText" FontFamily="Cascadia Mono,Consolas,monospace"
                                             FontSize="12" Padding="8" TextWrapping="NoWrap" />
                    </ScrollViewer>
                </Border>

            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
