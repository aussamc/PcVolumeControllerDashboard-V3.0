<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PcVolumeControllerDashboard.App"
        mc:Ignorable="d"
        x:Class="PcVolumeControllerDashboard.App.FirstRunWizard"
        Title="Set up your PC Volume Controller"
        Icon="/Assets/app-icon.ico"
        Width="640" Height="580"
        MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.step">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="24">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock x:Name="StepIndicatorText" Classes="step" Text="Step 1 of 5" />
            <TextBlock x:Name="StepTitleText" Classes="h1" Text="Welcome" Margin="0,4,0,0" />
        </StackPanel>

        <!-- ── Footer (buttons) ───────────────────────────────────────────── -->
        <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0" ColumnDefinitions="Auto,*,Auto,Auto">
            <Button x:Name="WizardBackButton" Grid.Column="0" Content="Back"
                    Click="Back_Click" />
            <Button x:Name="WizardSkipButton" Grid.Column="2" Content="Skip setup" Margin="0,0,8,0"
                    Click="Skip_Click"
                    ToolTip.Tip="Close the wizard and go straight to the dashboard. You can re-run setup later." />
            <Button x:Name="WizardNextButton" Grid.Column="3" Content="Next"
                    Classes="accent" Click="Next_Click" />
        </Grid>

        <!-- ── Step content (only one panel visible at a time) ─────────────── -->
        <!-- The named inline panels below are the fixed steps; the stream-specific
             UserControl pages (theme/audio/updates/app-setup) are added to this panel at
             runtime by the code-behind and toggled the same way. -->
        <Panel x:Name="StepHostPanel">

            <!-- Step 0 — Welcome -->
            <StackPanel x:Name="WelcomePanel">
                <TextBlock Classes="muted"
                           Text="This short setup will connect your controller, check its displays, and map each knob to an app or device." />
                <TextBlock Classes="muted"
                           Text="You can change any of this later from the dashboard, and re-run this wizard from the Setup tab." />
                <TextBlock Classes="muted" Margin="0,8,0,0"
                           Text="Make sure your PC Volume Controller is plugged in over USB, then click Next to begin." />
            </StackPanel>

            <!-- Step 1 — Stream chooser (Quick vs Advanced) -->
            <StackPanel x:Name="StreamChooserPanel" IsVisible="False">
                <TextBlock Classes="muted"
                           Text="Choose how much you want to configure now. You can change anything later from the Setup tab." />
                <RadioButton x:Name="QuickStreamRadio" GroupName="WizardStream" IsChecked="True" Margin="0,10,0,0">
                    <StackPanel MaxWidth="520">
                        <TextBlock Text="Quick setup" FontWeight="SemiBold" />
                        <TextBlock Classes="muted"
                                   Text="Connect, check the displays, assign your knobs, and pick a couple of preferences. Everything else uses recommended defaults." />
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="AdvancedStreamRadio" GroupName="WizardStream" Margin="0,8,0,0">
                    <StackPanel MaxWidth="520">
                        <TextBlock Text="Advanced setup" FontWeight="SemiBold" />
                        <TextBlock Classes="muted"
                                   Text="Everything in Quick, plus audio backend, theme, and software-update preferences." />
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- Step 1 — Connect / pair -->
            <StackPanel x:Name="ConnectPanel" IsVisible="False">
                <TextBlock Classes="muted"
                           Text="The dashboard is scanning your serial ports for the controller. This usually takes a few seconds after you plug it in." />
                <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        CornerRadius="8" Padding="14" Margin="0,8,0,8">
                    <StackPanel>
                        <TextBlock Text="Connection status" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock x:Name="WizardConnStatusText" Text="Searching for controller…" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Button x:Name="WizardScanButton" Content="Scan again" Click="Scan_Click"
                        ToolTip.Tip="Re-scan the COM ports for the controller" />
                <TextBlock Classes="muted" Margin="0,10,0,0"
                           Text="No controller yet? Check the USB cable and that no other program is using the port. You can also Skip setup and connect later." />
            </StackPanel>

            <!-- Step 2 — Identify OLEDs -->
            <StackPanel x:Name="IdentifyPanel" IsVisible="False">
                <TextBlock Classes="muted"
                           Text="Let's make sure the controller's displays are working. Click the button below and each of the six OLED screens will briefly show its channel number (1–6)." />
                <Button x:Name="WizardIdentifyButton" Content="Flash the displays" Click="Identify_Click"
                        Margin="0,4,0,8"
                        ToolTip.Tip="Send an identify command so every OLED shows its channel number" />
                <TextBlock x:Name="WizardIdentifyHintText" Classes="muted"
                           Text="Note the physical position of each numbered display — that's the order the next step maps to apps." />
            </StackPanel>

            <!-- Step 3 — Assign channels -->
            <StackPanel x:Name="AssignPanel" IsVisible="False">
                <TextBlock Classes="muted"
                           Text="Choose what each knob controls. Master is your main system volume; app entries appear while the app is playing audio. Leave a channel Unassigned to set it up later." />
                <Button x:Name="WizardRefreshAppsButton" Content="Refresh apps" Click="RefreshApps_Click"
                        HorizontalAlignment="Left" Margin="0,0,0,10"
                        ToolTip.Tip="Re-scan for apps that are currently playing audio" />
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <StackPanel x:Name="AssignRowsPanel" Spacing="8" />
                </ScrollViewer>
                <TextBlock x:Name="WizardAssignHintText" Classes="muted" IsVisible="False" Margin="0,8,0,0"
                           Text="No audio targets were found. Make sure some apps are playing sound, then click Refresh apps." />
            </StackPanel>

            <!-- Step 4 — Done -->
            <StackPanel x:Name="DonePanel" IsVisible="False">
                <TextBlock Classes="muted"
                           Text="That's it — your controller is ready to use." />
                <TextBlock x:Name="WizardSummaryText" Classes="muted" />
                <TextBlock Classes="muted" Margin="0,8,0,0"
                           Text="Fine-tune channel actions, encoder feel, OLED display modes and more from the dashboard tabs. Click Finish to open it." />
            </StackPanel>

        </Panel>
    </DockPanel>
</Window>
