<Window x:Class="PcVolumeControllerDashboard.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PC Volume Controller Dashboard"
        Width="440"
        Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FFFFFF">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="PC Volume Controller Dashboard"
                       FontSize="20" FontWeight="SemiBold"/>
            <TextBlock x:Name="VersionTextBlock"
                       Text="Version: —"
                       FontSize="13"
                       Margin="0,4,0,0"
                       Foreground="#666666"/>
            <TextBlock x:Name="FirmwareTextBlock"
                       Text="Controller: Not connected"
                       FontSize="13"
                       Margin="0,2,0,0"
                       Foreground="#666666"/>
        </StackPanel>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- GitHub link -->
                <TextBlock FontSize="13" Margin="0,0,0,12">
                    <Run Text="Source code: " />
                    <Hyperlink x:Name="GitHubHyperlink"
                               NavigateUri="https://github.com/aussamc/PcVolumeControllerDashboard"
                               RequestNavigate="GitHubHyperlink_RequestNavigate">
                        github.com/aussamc/PcVolumeControllerDashboard
                    </Hyperlink>
                </TextBlock>

                <!-- Third-party credits -->
                <TextBlock Text="Third-party components:" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                <TextBlock FontSize="12" Foreground="#444444" TextWrapping="Wrap" Margin="0,0,0,4">
                    <Run FontWeight="SemiBold">NAudio</Run>
                    <Run Text=" (v2.2.1) — Mark Heath — MIT License" />
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#444444" TextWrapping="Wrap" Margin="0,0,0,4">
                    <Run FontWeight="SemiBold">System.IO.Ports</Run>
                    <Run Text=" — .NET Foundation — MIT License" />
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#444444" TextWrapping="Wrap" Margin="0,0,0,4">
                    <Run FontWeight="SemiBold">ESP32-S3 Arduino Core</Run>
                    <Run Text=" — Espressif — LGPL v2.1" />
                </TextBlock>
                <TextBlock FontSize="12" Foreground="#444444" TextWrapping="Wrap" Margin="0,0,0,4">
                    <Run FontWeight="SemiBold">esptool.py</Run>
                    <Run Text=" — GPL v2" />
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CloseButton"
                    Content="Close"
                    Width="80" Height="30"
                    IsDefault="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
