# Shell scripts and Linux desktop entries run on Linux — keep them LF always,
# regardless of a contributor's core.autocrlf setting (CRLF breaks the shebang).
*.sh            text eol=lf
*.desktop       text eol=lf
AppRun          text eol=lf

# Binary assets — never apply line-ending or text normalization.
*.png           binary
*.ico           binary
*.AppImage      binary
